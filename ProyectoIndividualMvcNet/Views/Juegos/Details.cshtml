@using ProyectoIndividualMvcNet.Extensions
@model ProyectoIndividualMvcNet.Models.Juego

@{
    ViewData["Title"] = Model.Titulo;
    var isAdmin = ViewBag.IsAdmin ?? false;
    var resenas = ViewBag.Resenas as List<ProyectoIndividualMvcNet.Models.Resena> ?? new List<ProyectoIndividualMvcNet.Models.Resena>();
    var usuario = Context.Session.GetObject<ProyectoIndividualMvcNet.Models.Usuario>("USUARIO");

    // Calcular promedio de calificación
    double promedioNota = resenas.Any() ? resenas.Average(r => r.Nota) : 0;
    int totalResenas = resenas.Count;
}

<!-- Breadcrumb -->
<div class="container mt-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <i class="bi bi-house-door"></i> Inicio
                </a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" class="text-decoration-none">
                    <i class="bi bi-controller"></i> Juegos
                </a>
            </li>
            <li class="breadcrumb-item active text-white" aria-current="page">@Model.Titulo</li>
        </ol>
    </nav>
</div>

<!-- Detalles del Juego -->
<div class="container mb-5">
    <div class="row g-4">
        <!-- Columna Izquierda: Imagen y Galería -->
        <div class="col-lg-5">
            <!-- Imagen Principal -->
            <div class="card bg-dark border-0 shadow-lg sticky-top" style="top: 100px;">
                <div class="position-relative overflow-hidden rounded-3">
                    @if (!string.IsNullOrEmpty(Model.Img))
                    {
                        <img src="@Model.Img" class="img-fluid w-100" alt="@Model.Titulo" style="max-height: 500px; object-fit: cover;">
                        <div class="position-absolute top-0 start-0 w-100 h-100"
                             style="background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.7) 100%);"></div>
                    }
                    else
                    {
                        <div class="bg-secondary d-flex align-items-center justify-content-center" style="height: 400px;">
                            <i class="bi bi-controller text-white" style="font-size: 5rem; opacity: 0.3;"></i>
                        </div>
                    }

                    <!-- Badges Superpuestos -->
                    <div class="position-absolute top-0 start-0 m-3">
                        @if (Model.Stock > 0)
                        {
                            <span class="badge bg-success fs-6 px-3 py-2 shadow">
                                <i class="bi bi-check-circle me-1"></i>En Stock (@Model.Stock disponibles)
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger fs-6 px-3 py-2 shadow">
                                <i class="bi bi-x-circle me-1"></i>Agotado
                            </span>
                        }
                    </div>

                    @if (Model.Activo)
                    {
                        <div class="position-absolute top-0 end-0 m-3">
                            <span class="badge" style="background: var(--gaming-primary); color: #000; font-size: 0.9rem; padding: 8px 15px;">
                                <i class="bi bi-star-fill me-1"></i>Activo
                            </span>
                        </div>
                    }
                </div>

                <!-- Precio y Acción -->
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <small class="text-muted d-block mb-1">Precio</small>
                            <h2 class="mb-0 fw-bold" style="color: var(--gaming-primary);">
                                @Model.Precio.ToString("C")
                            </h2>
                        </div>
                        @if (Model.Stock > 0)
                        {
                            <form asp-action="AgregarAlCarrito" method="post" class="d-flex align-items-center gap-3">
                                <input type="hidden" name="idJuego" value="@Model.Id" />

                                <!-- Input de cantidad -->
                                <div class="quantity-selector">
                                    <label for="cantidad" class="form-label text-white mb-1 small">Cantidad:</label>
                                    <div class="input-group" style="width: 120px;">
                                        <button type="button" class="btn btn-outline-light btn-sm" onclick="decrementQuantity()">
                                            <i class="bi bi-dash"></i>
                                        </button>
                                        <input type="number"
                                               id="cantidad"
                                               name="cantidad"
                                               class="form-control form-control-sm text-center bg-dark text-white"
                                               value="1"
                                               min="1"
                                               max="@Model.Stock"
                                               style="border-left: none; border-right: none;" />
                                        <button type="button" class="btn btn-outline-light btn-sm" onclick="incrementQuantity(@Model.Stock)">
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    </div>
                                    <small class="text-muted">Stock: @Model.Stock</small>
                                </div>

                                <!-- Botón agregar -->
                                <button type="submit" class="btn btn-gaming btn-lg shadow-lg">
                                    <i class="bi bi-cart-plus me-2"></i>Añadir al Carrito
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-lg" disabled>
                                <i class="bi bi-x-circle me-2"></i>No Disponible
                            </button>
                        }
                    </div>

                    <!-- Botones de acción secundarios -->
                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-light">
                            <i class="bi bi-heart me-2"></i>Añadir a Favoritos
                        </button>
                        <button class="btn btn-outline-light">
                            <i class="bi bi-share me-2"></i>Compartir
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Columna Derecha: Información del Juego -->
        <div class="col-lg-7">
            <!-- Encabezado -->
            <div class="mb-4">
                <h1 class="display-4 fw-bold text-white mb-3">@Model.Titulo</h1>

                <!-- Tags -->
                <div class="mb-4">
                    @if (!string.IsNullOrEmpty(Model.Genero))
                    {
                        <span class="badge bg-primary fs-6 px-3 py-2 me-2">
                            <i class="bi bi-tag-fill me-1"></i>@Model.Genero
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Plataforma))
                    {
                        <span class="badge bg-info fs-6 px-3 py-2">
                            <i class="bi bi-joystick me-1"></i>@Model.Plataforma
                        </span>
                    }
                </div>

                <!-- Calificación Real -->
                <div class="d-flex align-items-center mb-4">
                    <div class="text-warning me-2" style="font-size: 1.5rem;">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Floor(promedioNota))
                            {
                                <i class="bi bi-star-fill"></i>
                            }
                            else if (i - 0.5 <= promedioNota)
                            {
                                <i class="bi bi-star-half"></i>
                            }
                            else
                            {
                                <i class="bi bi-star"></i>
                            }
                        }
                    </div>
                    <span class="text-muted">@promedioNota.ToString("F1") / 5.0 (@totalResenas reseñas)</span>
                </div>
            </div>

            <!-- Descripción -->
            <div class="card bg-dark border-0 shadow mb-4">
                <div class="card-header border-0 py-3" style="background: linear-gradient(90deg, var(--gaming-primary) 0%, transparent 100%);">
                    <h5 class="mb-0 text-white">
                        <i class="bi bi-info-circle me-2"></i>Descripción
                    </h5>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.Descripcion))
                    {
                        <p class="text-light fs-5 mb-0 lh-lg">@Model.Descripcion</p>
                    }
                    else
                    {
                        <p class="text-muted fst-italic mb-0">Sin descripción disponible.</p>
                    }
                </div>
            </div>

            <!-- Detalles Técnicos -->
            <div class="card bg-dark border-0 shadow mb-4">
                <div class="card-header border-0 py-3" style="background: linear-gradient(90deg, var(--gaming-secondary) 0%, transparent 100%);">
                    <h5 class="mb-0 text-white">
                        <i class="bi bi-list-check me-2"></i>Detalles Técnicos
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="p-3 bg-dark rounded border border-secondary">
                                <small class="text-muted d-block mb-1">
                                    <i class="bi bi-hash me-1"></i>ID del Producto
                                </small>
                                <strong class="text-white fs-5">#@Model.Id.ToString("D5")</strong>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-dark rounded border border-secondary">
                                <small class="text-muted d-block mb-1">
                                    <i class="bi bi-tag me-1"></i>Género
                                </small>
                                <strong class="text-white fs-5">@(Model.Genero ?? "No especificado")</strong>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-dark rounded border border-secondary">
                                <small class="text-muted d-block mb-1">
                                    <i class="bi bi-joystick me-1"></i>Plataforma
                                </small>
                                <strong class="text-white fs-5">@(Model.Plataforma ?? "No especificado")</strong>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-dark rounded border border-secondary">
                                <small class="text-muted d-block mb-1">
                                    <i class="bi bi-box-seam me-1"></i>Stock Disponible
                                </small>
                                <strong class="fs-5" style="color: @(Model.Stock > 0 ? "var(--gaming-primary)" : "var(--gaming-accent)");">
                                    @Model.Stock unidades
                                </strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Características -->
            <div class="card bg-dark border-0 shadow mb-4">
                <div class="card-header border-0 py-3" style="background: linear-gradient(90deg, var(--gaming-accent) 0%, transparent 100%);">
                    <h5 class="mb-0 text-white">
                        <i class="bi bi-shield-check me-2"></i>Características
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3 text-light">
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-success me-2 fs-5"></i>
                                <span>Envío gratis en compras superiores a 50€</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-success me-2 fs-5"></i>
                                <span>Devolución en 30 días</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-success me-2 fs-5"></i>
                                <span>Garantía oficial del fabricante</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-check-circle-fill text-success me-2 fs-5"></i>
                                <span>Pago seguro 100%</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Botones de Administrador -->
            @if (isAdmin)
            {
                <div class="card border-warning shadow mb-4">
                    <div class="card-header bg-warning text-dark py-3">
                        <h5 class="mb-0">
                            <i class="bi bi-shield-lock-fill me-2"></i>Panel de Administrador
                        </h5>
                    </div>
                    <div class="card-body bg-dark">
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-idjuego="@Model.Id" class="btn btn-warning flex-fill">
                                <i class="bi bi-pencil-square me-2"></i>Editar Juego
                            </a>
                            <a asp-action="Delete" asp-route-idjuego="@Model.Id" class="btn btn-danger flex-fill">
                                <i class="bi bi-trash me-2"></i>Eliminar
                            </a>
                        </div>
                    </div>
                </div>
            }

            <!-- Botón Volver -->
            <div class="text-center mt-4">
                <a asp-action="Index" class="btn btn-outline-light btn-lg px-5">
                    <i class="bi bi-arrow-left me-2"></i>Volver al Catálogo
                </a>
            </div>
        </div>
    </div>

    <!-- Sección de Reseñas -->
    <div class="row mt-5">
        <div class="col-12">
            <div class="card bg-dark border-0 shadow">
                <div class="card-header border-0 py-4" style="background: linear-gradient(90deg, var(--gaming-primary) 0%, transparent 100%);">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-chat-square-quote me-2"></i>Reseñas de Usuarios (@totalResenas)
                    </h4>
                </div>
                <div class="card-body">
                    <!-- Formulario para agregar reseña -->
                    @if (usuario != null)
                    {
                        <div class="mb-4 p-4 rounded" style="background: rgba(0, 255, 136, 0.05); border: 1px solid rgba(0, 255, 136, 0.2);">
                            <h5 class="text-white mb-3">
                                <i class="bi bi-pencil-square me-2" style="color: var(--gaming-primary);"></i>
                                Escribe tu reseña
                            </h5>
                            <form asp-action="PostResena" method="post">
                                <input type="hidden" name="idJuego" value="@Model.Id" />

                                <!-- Selector de calificación -->
                                <div class="mb-3">
                                    <label class="form-label text-white fw-bold">
                                        <i class="bi bi-star-fill text-warning me-2"></i>Calificación
                                    </label>
                                    <div class="d-flex gap-2">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            int rating = i;
                                            <label class="star-rating-label">
                                                <input type="radio" name="nota" value="@rating" required class="d-none" />
                                                <i class="bi bi-star fs-2" data-rating="@rating"></i>
                                            </label>
                                        }
                                    </div>
                                    <small class="text-muted">Haz clic en las estrellas para calificar</small>
                                </div>

                                <!-- Campo de comentario -->
                                <div class="mb-3">
                                    <label for="comentario" class="form-label text-white fw-bold">
                                        <i class="bi bi-chat-left-text me-2"></i>Tu opinión
                                    </label>
                                    <textarea name="comentario"
                                          id="comentario"
                                          class="form-control bg-dark text-white border-secondary"
                                          rows="4"
                                          placeholder="Comparte tu experiencia con este juego..."
                                          required
                                          maxlength="500"></textarea>
                                    <small class="text-muted">Máximo 500 caracteres</small>
                                </div>

                                <!-- Botón enviar -->
                                <button type="submit" class="btn btn-lg shadow-lg w-100" style="background: var(--gaming-primary); color: #000; font-weight: bold;">
                                    <i class="bi bi-send me-2"></i>Publicar Reseña
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info d-flex align-items-center mb-4">
                            <i class="bi bi-info-circle-fill me-3 fs-4"></i>
                            <div>
                                <strong>Inicia sesión para dejar una reseña</strong>
                                <p class="mb-0 mt-1">
                                    <a asp-controller="Usuarios" asp-action="Login" class="text-decoration-none" style="color: var(--gaming-primary);">
                                        Haz clic aquí para iniciar sesión
                                    </a>
                                </p>
                            </div>
                        </div>
                    }

                    <!-- Lista de reseñas -->
                    @if (resenas.Any())
                    {
                        <div id="resenas-container">
                            @foreach (var resena in resenas)
                            {
                                <div class="border-bottom border-secondary pb-4 mb-4 resena-item">
                                    <div class="d-flex align-items-start mb-2">
                                        <div class="user-avatar me-3" style="width: 50px; height: 50px; flex-shrink: 0;">
                                            @if (!string.IsNullOrEmpty(resena.Usuario?.Imagen))
                                            {
                                                <img src="@resena.Usuario.Imagen" class="rounded-circle w-100 h-100" style="object-fit: cover;" alt="Avatar" />
                                            }
                                            else
                                            {
                                                <i class="bi bi-person-fill"></i>
                                            }
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <div>
                                                    <h6 class="text-white mb-1">@(resena.Usuario?.Nombre ?? "Usuario")</h6>
                                                    <div class="text-warning">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            if (i <= resena.Nota)
                                                            {
                                                                <i class="bi bi-star-fill"></i>
                                                            }
                                                            else
                                                            {
                                                                <i class="bi bi-star"></i>
                                                            }
                                                        }
                                                    </div>
                                                </div>
                                                <small class="text-muted">@GetTiempoTranscurrido(resena.Fecha)</small>
                                            </div>
                                            <p class="text-light mb-0">@resena.Comentario</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-chat-square-quote" style="font-size: 4rem; color: var(--gaming-primary); opacity: 0.3;"></i>
                            <h5 class="text-muted mt-3">No hay reseñas todavía</h5>
                            <p class="text-muted">¡Sé el primero en compartir tu opinión sobre este juego!</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Notificación de éxito -->
@if (TempData["MENSAJE"] != null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
        <div class="toast show" role="alert">
            <div class="toast-header" style="background: var(--gaming-primary); color: #000;">
                <i class="bi bi-check-circle-fill me-2"></i>
                <strong class="me-auto">¡Éxito!</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body bg-dark text-white">
                @TempData["MENSAJE"]
            </div>
        </div>
    </div>
}

@functions {
    string GetTiempoTranscurrido(DateTime fecha)
    {
        var tiempo = DateTime.Now - fecha;

        if (tiempo.TotalMinutes < 1) return "Hace un momento";
        if (tiempo.TotalMinutes < 60) return $"Hace {(int)tiempo.TotalMinutes} minutos";
        if (tiempo.TotalHours < 24) return $"Hace {(int)tiempo.TotalHours} horas";
        if (tiempo.TotalDays < 30) return $"Hace {(int)tiempo.TotalDays} días";
        if (tiempo.TotalDays < 365) return $"Hace {(int)(tiempo.TotalDays / 30)} meses";
        return $"Hace {(int)(tiempo.TotalDays / 365)} años";
    }
}

<style>
    .sticky-top {
        position: sticky;
        top: 100px;
        z-index: 10;
    }

    /* Estilo para el sistema de estrellas */
    .star-rating-label {
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .star-rating-label i {
            color: #6c757d;
            transition: all 0.2s ease;
        }

        /* Estrella activa (llenada) */
        .star-rating-label i.active {
            color: #ffc107;
        }

        .star-rating-label:hover i,
        .star-rating-label:hover ~ .star-rating-label i,
        .star-rating-label input:checked ~ i,
        .star-rating-label input:checked ~ .star-rating-label i {
            color: #ffc107 !important;
        }

        /* Efecto hover en las estrellas de calificación */
        .star-rating-label:hover i {
            color: #ffc107 !important;
            transform: scale(1.2);
        }

    /* Animación para las reseñas */
    .resena-item {
        animation: fadeInUp 0.5s ease;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Toast notification */
    .toast {
        border: 2px solid var(--gaming-primary);
    }

    /* Selector de cantidad */
    .quantity-selector {
        text-align: center;
    }

        .quantity-selector .input-group {
            box-shadow: 0 2px 8px rgba(0, 255, 136, 0.2);
            border-radius: 8px;
            overflow: hidden;
        }

        .quantity-selector .btn {
            border-color: var(--gaming-primary);
            color: var(--gaming-primary);
        }

            .quantity-selector .btn:hover {
                background-color: var(--gaming-primary);
                color: #000;
            }

        .quantity-selector input[type="number"] {
            font-weight: 700;
            font-size: 1rem;
        }

            /* Ocultar las flechas del input number (opcional) */
            .quantity-selector input[type="number"]::-webkit-inner-spin-button,
            .quantity-selector input[type="number"]::-webkit-outer-spin-button {
                -webkit-appearance: none;
                margin: 0;
            }

        .quantity-selector input[type="number"] {
            -moz-appearance: textfield;
        }
</style>

@section Scripts {
    <!-- Scripts existentes -->

    <script>
        // Función para incrementar cantidad
        function incrementQuantity(maxStock) {
            const input = document.getElementById('cantidad');
            let value = parseInt(input.value) || 1;
            if (value < maxStock) {
                input.value = value + 1;
            }
        }

        // Función para decrementar cantidad
        function decrementQuantity() {
            const input = document.getElementById('cantidad');
            let value = parseInt(input.value) || 1;
            if (value > 1) {
                input.value = value - 1;
            }
        }

        // Validar que no se exceda el stock al escribir manualmente
        document.getElementById('cantidad')?.addEventListener('input', function() {
            const maxStock = parseInt(this.max);
            let value = parseInt(this.value);

            if (value < 1) {
                this.value = 1;
            } else if (value > maxStock) {
                this.value = maxStock;
            }
        });

        // Calificación por estrellas
        document.addEventListener('DOMContentLoaded', function () {
    const starLabels = document.querySelectorAll('.star-rating-label');

    if (starLabels.length === 0) {
        return;
    }

    function pintarHasta(valor) {
        starLabels.forEach(label => {
            const icon = label.querySelector('i[data-rating]');
            const rating = parseInt(icon.getAttribute('data-rating'));

            if (rating <= valor) {
                icon.classList.add('active');
            } else {
                icon.classList.remove('active');
            }
        });
    }

    starLabels.forEach(label => {
        const input = label.querySelector('input[type="radio"]');
        const icon = label.querySelector('i[data-rating]');
        const valor = parseInt(icon.getAttribute('data-rating'));

        // Click: marca el radio y pinta hasta esa estrella
        label.addEventListener('click', function () {
            input.checked = true;
            pintarHasta(valor);
        });

        // Hover: mostrar preview sin cambiar el valor marcado
        label.addEventListener('mouseenter', function () {
            pintarHasta(valor);
        });
    });

    // Al salir del área de estrellas, restaurar según el radio seleccionado
    const starsContainer = starLabels[0].parentElement;
    starsContainer.addEventListener('mouseleave', function () {
        const checked = document.querySelector('.star-rating-label input[type="radio"]:checked');
        if (checked) {
            const valor = parseInt(checked.value);
            pintarHasta(valor);
        } else {
            pintarHasta(0);
        }
    });

    // Estado inicial (por si quieres que empiece en 5, etc.)
    const inicial = document.querySelector('.star-rating-label input[type="radio"]:checked');
    if (inicial) {
