@model ProyectoIndividualMvcNet.Models.Juego

@{
    ViewData["Title"] = "Editar Juego";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card bg-dark border-0 shadow-lg">
                <div class="card-header text-white" style="background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);">
                    <h2 class="mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Editar Juego
                    </h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">

                        <input type="hidden" asp-for="Id" />

                        <!-- Título -->
                        <div class="mb-3">
                            <label asp-for="Titulo" class="form-label text-white">
                                <i class="bi bi-joystick me-2"></i>Título del Juego
                            </label>
                            <input asp-for="Titulo" class="form-control form-control-lg bg-dark text-white border-secondary" />
                            <span asp-validation-for="Titulo" class="text-danger"></span>
                        </div>

                        <!-- Descripción -->
                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label text-white">
                                <i class="bi bi-card-text me-2"></i>Descripción
                            </label>
                            <textarea asp-for="Descripcion" class="form-control bg-dark text-white border-secondary" rows="4"></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <!-- Género - SELECT -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Genero" class="form-label text-white">
                                    <i class="bi bi-tag-fill me-2"></i>Género
                                </label>
                                <select asp-for="Genero" class="form-select form-select-lg bg-dark text-white border-secondary">
                                    <option value="">Selecciona un género</option>
                                    <option value="Acción">Acción</option>
                                    <option value="Aventura">Aventura</option>
                                    <option value="RPG">RPG</option>
                                    <option value="Deportes">Deportes</option>
                                    <option value="Estrategia">Estrategia</option>
                                    <option value="Simulación">Simulación</option>
                                    <option value="Carreras">Carreras</option>
                                    <option value="Terror">Terror</option>
                                </select>
                                <span asp-validation-for="Genero" class="text-danger"></span>
                            </div>

                            <!-- Plataforma - SELECT -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Plataforma" class="form-label text-white">
                                    <i class="bi bi-controller me-2"></i>Plataforma
                                </label>
                                <select asp-for="Plataforma" class="form-select form-select-lg bg-dark text-white border-secondary">
                                    <option value="">Selecciona una plataforma</option>
                                    <option value="PC">PC</option>
                                    <option value="PlayStation">PlayStation</option>
                                    <option value="Xbox">Xbox</option>
                                    <option value="Nintendo Switch">Nintendo Switch</option>
                                    <option value="Multiplataforma">Multiplataforma</option>
                                </select>
                                <span asp-validation-for="Plataforma" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Precio -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Precio" class="form-label text-white">
                                    <i class="bi bi-cash me-2"></i>Precio (€)
                                </label>
                                <input asp-for="Precio" type="number" step="0.01" class="form-control form-control-lg bg-dark text-white border-secondary" />
                                <span asp-validation-for="Precio" class="text-danger"></span>
                            </div>

                            <!-- Stock -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Stock" class="form-label text-white">
                                    <i class="bi bi-box-seam me-2"></i>Stock
                                </label>
                                <input asp-for="Stock" type="number" class="form-control form-control-lg bg-dark text-white border-secondary" />
                                <span asp-validation-for="Stock" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Imagen actual -->
                        @if (!string.IsNullOrEmpty(Model.Img))
                        {
                            <div class="mb-3">
                                <label class="form-label text-white">
                                    <i class="bi bi-image me-2"></i>Imagen Actual
                                </label>
                                <div class="text-center">
                                    <img src="@Model.Img"
                                         alt="@Model.Titulo"
                                         style="max-width: 300px; max-height: 300px; object-fit: cover; border-radius: 10px;"
                                         class="img-thumbnail bg-dark border-secondary" />
                                </div>
                            </div>
                        }

                        <!-- Nueva imagen -->
                        <div class="mb-3">
                            <label for="imagenFile" class="form-label text-white">
                                <i class="bi bi-upload me-2"></i>Cambiar Imagen
                            </label>
                            <input type="file"
                                   class="form-control form-control-lg bg-dark text-white border-secondary"
                                   id="imagenFile"
                                   name="imagenFile"
                                   accept="image/*" />
                            <small class="text-muted">Deja vacío para mantener la imagen actual</small>
                        </div>

                        <!-- Activo -->
                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input asp-for="Activo" class="form-check-input" type="checkbox" />
                                <label asp-for="Activo" class="form-check-label text-white">
                                    <i class="bi bi-toggle-on me-2"></i>Juego activo (visible en tienda)
                                </label>
                            </div>
                        </div>

                        <!-- Botones -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                                <i class="bi bi-x-circle me-2"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-lg px-4 shadow-lg" style="background: #ffc107; color: #000; font-weight: bold;">
                                <i class="bi bi-save me-2"></i>Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    .form-control:focus, .form-select:focus {
        border-color: #ffc107;
        box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25);
    }
</style>