@model ProyectoIndividualMvcNet.Models.Juego

@{
    ViewData["Title"] = "Editar Juego";
}
<div class="container mt-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-white">
                    <i class="bi bi-house-door"></i> Inicio
                </a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" class="text-decoration-none text-white">
                    <i class="bi bi-controller"></i> Juegos
                </a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Details" asp-route-idjuego="@Model.Id" class="text-decoration-none text-white">
                    @Model.Titulo
                </a>
            </li>
            <li class="breadcrumb-item active" style="color: var(--gaming-primary, #00d9ff);" aria-current="page">
                Editar
            </li>
        </ol>
    </nav>
</div>

<!-- Header -->
<div class="container mb-4">
    <div class="text-center">
        <h1 class="display-4 fw-bold text-white mb-2">
            <i class="bi bi-pencil-square me-3" style="color: var(--gaming-primary, #00d9ff);"></i>
            Editar Juego
        </h1>
        <p class="lead text-white-50">Modifica la información de: <strong style="color: var(--gaming-primary, #00d9ff);">@Model.Titulo</strong></p>
    </div>
</div>

<!-- Formulario -->
<div class="container mb-5">
    <div class="row">
        <!-- Columna del formulario -->
        <div class="col-lg-8">
            <div class="card bg-dark border-0 shadow-lg">
                <div class="card-header border-0 py-4" style="background: linear-gradient(90deg, var(--gaming-secondary, #8b5cf6) 0%, transparent 100%);">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-file-earmark-text me-2"></i>Información del Juego
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 mb-4" role="alert"></div>

                        <!-- Título -->
                        <div class="mb-4">
                            <label asp-for="Titulo" class="form-label text-white fw-bold">
                                <i class="bi bi-type me-2"></i>Título del Juego
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Titulo" class="form-control form-control-lg bg-dark text-white border-secondary" placeholder="Ej: The Legend of Zelda: Breath of the Wild" />
                            <span asp-validation-for="Titulo" class="text-danger small"></span>
                        </div>

                        <!-- Descripción -->
                        <div class="mb-4">
                            <label asp-for="Descripcion" class="form-label text-white fw-bold">
                                <i class="bi bi-text-paragraph me-2"></i>Descripción
                            </label>
                            <textarea asp-for="Descripcion" class="form-control bg-dark text-white border-secondary" rows="4" placeholder="Describe las características y detalles del juego..."></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>

                        <!-- Género y Plataforma -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="Genero" class="form-label text-white fw-bold">
                                    <i class="bi bi-tag-fill me-2"></i>Género
                                    <span class="text-danger">*</span>
                                </label>
                                <select asp-for="Genero" class="form-select form-select-lg bg-dark text-white border-secondary">
                                    <option value="">Selecciona un género</option>
                                    <option value="Acción">Acción</option>
                                    <option value="Aventura">Aventura</option>
                                    <option value="RPG">RPG</option>
                                    <option value="Deportes">Deportes</option>
                                    <option value="Estrategia">Estrategia</option>
                                    <option value="Simulación">Simulación</option>
                                    <option value="Terror">Terror</option>
                                    <option value="Lucha">Lucha</option>
                                    <option value="Carreras">Carreras</option>
                                    <option value="Plataformas">Plataformas</option>
                                </select>
                                <span asp-validation-for="Genero" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Plataforma" class="form-label text-white fw-bold">
                                    <i class="bi bi-joystick me-2"></i>Plataforma
                                    <span class="text-danger">*</span>
                                </label>
                                <select asp-for="Plataforma" class="form-select form-select-lg bg-dark text-white border-secondary">
                                    <option value="">Selecciona una plataforma</option>
                                    <option value="PlayStation">PlayStation</option>
                                    <option value="Xbox">Xbox</option>
                                    <option value="Nintendo Switch">Nintendo Switch</option>
                                    <option value="PC">PC</option>
                                    <option value="PlayStation 5">PlayStation 5</option>
                                    <option value="Xbox Series X|S">Xbox Series X|S</option>
                                    <option value="Multi-Plataforma">Multi-Plataforma</option>
                                </select>
                                <span asp-validation-for="Plataforma" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Precio y Stock -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="Precio" class="form-label text-white fw-bold">
                                    <i class="bi bi-currency-dollar me-2"></i>Precio
                                    <span class="text-danger">*</span>
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-dark text-white border-secondary">$</span>
                                    <input asp-for="Precio" type="number" step="0.01" min="0" class="form-control bg-dark text-white border-secondary" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Precio" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Stock" class="form-label text-white fw-bold">
                                    <i class="bi bi-box-seam me-2"></i>Stock Disponible
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Stock" type="number" min="0" class="form-control form-control-lg bg-dark text-white border-secondary" placeholder="0" />
                                <span asp-validation-for="Stock" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- URL de Imagen -->
                        <div class="mb-4">
                            <label asp-for="Img" class="form-label text-white fw-bold">
                                <i class="bi bi-image me-2"></i>URL de la Imagen
                            </label>
                            <input asp-for="Img" class="form-control form-control-lg bg-dark text-white border-secondary" placeholder="https://ejemplo.com/imagen.jpg" />
                            <span asp-validation-for="Img" class="text-danger small"></span>
                            <small class="text-white-50 d-block mt-2">
                                <i class="bi bi-info-circle me-1"></i>Proporciona la URL de una imagen del juego (opcional)
                            </small>
                        </div>

                        <!-- Estado Activo -->
                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input asp-for="Activo" class="form-check-input" type="checkbox" id="checkActivo" style="width: 3rem; height: 1.5rem; cursor: pointer;">
                                <label class="form-check-label text-white fw-bold ms-2" for="checkActivo">
                                    <i class="bi bi-toggle-on me-2"></i>Juego Activo
                                </label>
                            </div>
                            <small class="text-white-50 d-block ms-5">
                                Los juegos activos se mostrarán en el catálogo público
                            </small>
                        </div>

                        <!-- Botones de acción -->
                        <div class="row mt-5">
                            <div class="col-md-4 mb-3 mb-md-0">
                                <button type="submit" class="btn btn-lg w-100 shadow-lg" style="background: var(--gaming-secondary, #8b5cf6); color: #fff; font-weight: bold;">
                                    <i class="bi bi-check-circle me-2"></i>Guardar Cambios
                                </button>
                            </div>
                            <div class="col-md-4 mb-3 mb-md-0">
                                <a asp-action="Details" asp-route-idjuego="@Model.Id" class="btn btn-outline-light btn-lg w-100">
                                    <i class="bi bi-eye me-2"></i>Ver Detalles
                                </a>
                            </div>
                            <div class="col-md-4">
                                <a asp-action="Index" class="btn btn-outline-light btn-lg w-100">
                                    <i class="bi bi-x-circle me-2"></i>Cancelar
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Columna de información -->
        <div class="col-lg-4">
            <!-- Preview de la imagen -->
            <div class="card bg-dark border-0 shadow-lg mb-4">
                <div class="card-header border-0 py-3" style="background: linear-gradient(90deg, var(--gaming-primary, #00d9ff) 0%, transparent 100%);">
                    <h5 class="mb-0 text-white">
                        <i class="bi bi-image me-2"></i>Vista Previa
                    </h5>
                </div>
                <div class="card-body p-3">
                    <div class="position-relative overflow-hidden rounded-3 mb-3" style="height: 200px;">
                        @if (!string.IsNullOrEmpty(Model.Img))
                        {
                            <img src="@Model.Img" class="w-100 h-100" alt="Preview" style="object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-secondary d-flex align-items-center justify-content-center h-100">
                                <i class="bi bi-controller text-white" style="font-size: 3rem; opacity: 0.3;"></i>
                            </div>
                        }
                    </div>
                    <small class="text-white-50">
                        <i class="bi bi-info-circle me-1"></i>Imagen actual del juego
                    </small>
                </div>
            </div>

            <!-- Información del juego -->
            <div class="card bg-dark border-0 shadow-lg mb-4">
                <div class="card-header border-0 py-3" style="background: linear-gradient(90deg, var(--gaming-accent, #ff006e) 0%, transparent 100%);">
                    <h5 class="mb-0 text-white">
                        <i class="bi bi-info-circle me-2"></i>Información
                    </h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">ID del Juego</small>
                        <strong class="text-white fs-5">#@Model.Id.ToString("D5")</strong>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">Estado Actual</small>
                        @if (Model.Activo)
                        {
                            <span class="badge bg-success fs-6 px-3 py-2">
                                <i class="bi bi-check-circle me-1"></i>Activo
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary fs-6 px-3 py-2">
                                <i class="bi bi-x-circle me-1"></i>Inactivo
                            </span>
                        }
                    </div>
                    <div>
                        <small class="text-muted d-block mb-1">Stock Actual</small>
                        <strong class="text-white fs-5">@Model.Stock unidades</strong>
                    </div>
                </div>
            </div>

            <!-- Consejos -->
            
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    .form-control:focus,
    .form-select:focus {
        background-color: #1a1a2e !important;
        color: white !important;
        border-color: var(--gaming-primary, #00d9ff) !important;
        box-shadow: 0 0 0 0.25rem rgba(0, 217, 255, 0.25) !important;
    }

    .form-select option {
        background-color: #1a1a2e;
        color: white;
    }

    .form-check-input:checked {
        background-color: var(--gaming-primary, #00d9ff);
        border-color: var(--gaming-primary, #00d9ff);
    }

    .form-check-input:focus {
        border-color: var(--gaming-primary, #00d9ff);
        box-shadow: 0 0 0 0.25rem rgba(0, 217, 255, 0.25);
    }

    :root {
        --gaming-primary: #00d9ff;
        --gaming-secondary: #8b5cf6;
        --gaming-accent: #ff006e;
    }
</style>