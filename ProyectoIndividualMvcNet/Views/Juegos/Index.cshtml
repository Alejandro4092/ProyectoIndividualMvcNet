@using ProyectoIndividualMvcNet.Extensions
@model IEnumerable<ProyectoIndividualMvcNet.Models.Juego>

@{
    ViewData["Title"] = "Tienda de Juegos";
    var isAdmin = ViewBag.IsAdmin ?? false;
    var texto = ViewData["TEXTO"] as string ?? "";
    var genero = ViewData["GENERO"] as string ?? "";
    var plataforma = ViewData["PLATAFORMA"] as string ?? "";
    
    // Obtener el carrito de la sesión
    var carrito = Context.Session.GetObject<List<ProyectoIndividualMvcNet.Models.Juego>>("CARRITO") 
                  ?? new List<ProyectoIndividualMvcNet.Models.Juego>();
    int cantidadCarrito = carrito.Count;
}

<!-- Hero Section - SIN botón Mi Carrito -->
<div class="bg-dark text-white py-5 mb-4">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold mb-3">
                    <i class="bi bi-controller me-2"></i>Catálogo de Juegos
                </h1>
                <p class="lead mb-0">Descubre nuestra increíble colección de videojuegos</p>
            </div>
            @if (isAdmin)
            {
                <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                    <a asp-action="Create" class="btn btn-success btn-lg shadow">
                        <i class="bi bi-plus-circle me-2"></i>Agregar Juego
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Filtros y búsqueda -->
<div class="container mb-4">
    <form asp-action="Index" method="get">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="texto" class="form-control" placeholder="Buscar juegos..." value="@texto">
                </div>
            </div>
            <div class="col-md-3">
                <select name="genero" class="form-select">
                    <option value="">Todos los géneros</option>
                    <option value="Acción" selected="@(genero == "Acción")">Acción</option>
                    <option value="Aventura" selected="@(genero == "Aventura")">Aventura</option>
                    <option value="RPG" selected="@(genero == "RPG")">RPG</option>
                    <option value="Deportes" selected="@(genero == "Deportes")">Deportes</option>
                    <option value="Estrategia" selected="@(genero == "Estrategia")">Estrategia</option>
                    <option value="Simulación" selected="@(genero == "Simulación")">Simulación</option>
                </select>
            </div>
            <div class="col-md-3">
                <select name="plataforma" class="form-select">
                    <option value="">Todas las plataformas</option>
                    <option value="PlayStation" selected="@(plataforma == "PlayStation")">PlayStation</option>
                    <option value="Xbox" selected="@(plataforma == "Xbox")">Xbox</option>
                    <option value="Nintendo Switch" selected="@(plataforma == "Nintendo Switch")">Nintendo Switch</option>
                    <option value="PC" selected="@(plataforma == "PC")">PC</option>
                </select>
            </div>
            <div class="col-md-2">
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-funnel-fill me-2"></i>Buscar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-clockwise me-2"></i>Limpiar
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="container">
    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (var juego in Model)
            {
                var estaEnCarrito = carrito.Any(j => j.Id == juego.Id);
                
                <div class="col">
                    <div class="card h-100 bg-dark border-0 shadow-lg game-card">
                        <!-- Imagen del juego -->
                        <div class="position-relative overflow-hidden" style="height: 250px;">
                            @if (!string.IsNullOrEmpty(juego.Img))
                            {
                                <img src="@juego.Img" class="card-img-top object-fit-cover h-100" alt="@juego.Titulo">
                            }
                            else
                            {
                                <div class="bg-secondary d-flex align-items-center justify-content-center h-100">
                                    <i class="bi bi-controller text-white" style="font-size: 3rem;"></i>
                                </div>
                            }

                            <!-- Badge de stock -->
                            @if (juego.Stock > 0)
                            {
                                <span class="badge bg-success position-absolute top-0 end-0 m-2">
                                    <i class="bi bi-check-circle me-1"></i>Disponible
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger position-absolute top-0 end-0 m-2">
                                    <i class="bi bi-x-circle me-1"></i>Agotado
                                </span>
                            }
                            
                            <!-- Badge "En el carrito" -->
                            @if (estaEnCarrito)
                            {
                                <span class="badge position-absolute top-0 start-0 m-2" style="background: var(--gaming-accent, #ff006e);">
                                    <i class="bi bi-cart-check me-1"></i>En el carrito
                                </span>
                            }
                        </div>

                        <div class="card-body d-flex flex-column">
                            <!-- Título -->
                            <h5 class="card-title text-white fw-bold text-truncate mb-2" title="@juego.Titulo">
                                @juego.Titulo
                            </h5>

                            <!-- Descripción -->
                            <p class="card-text text-muted small mb-3" style="height: 60px; overflow: hidden;">
                                @(juego.Descripcion?.Length > 100 ? juego.Descripcion.Substring(0, 100) + "..." : juego.Descripcion)
                            </p>

                            <!-- Géneros y Plataforma -->
                            <div class="mb-3">
                                @if (!string.IsNullOrEmpty(juego.Genero))
                                {
                                    <span class="badge bg-primary me-1">
                                        <i class="bi bi-tag-fill me-1"></i>@juego.Genero
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(juego.Plataforma))
                                {
                                    <span class="badge bg-info">
                                        <i class="bi bi-joystick me-1"></i>@juego.Plataforma
                                    </span>
                                }
                            </div>

                            <div class="mt-auto">
                                <!-- Precio -->
                                <div class="text-center mb-3">
                                    <h3 class="fw-bold mb-0" style="color: var(--gaming-primary, #00ff88);">
                                        @juego.Precio.ToString("C")
                                    </h3>
                                    <small class="text-muted">
                                        <i class="bi bi-box-seam me-1"></i>Stock: @juego.Stock
                                    </small>
                                </div>

                                @if (juego.Stock > 0)
                                {
                                    <!-- Botón de Compra Directa -->
                                    <form asp-action="Comprar" method="post" class="mb-2">
                                        <input type="hidden" name="idJuego" value="@juego.Id" />
                                        <input type="hidden" name="precio" value="@juego.Precio" />
                                        <button type="submit" class="btn btn-lg w-100 shadow-lg btn-comprar-ahora">
                                            <i class="bi bi-lightning-charge-fill me-2"></i>Comprar Ahora
                                        </button>
                                    </form>
                                    
                                    <!-- Selector de cantidad + Añadir al Carrito -->
                                    @if (!estaEnCarrito)
                                    {
                                        <form asp-action="AgregarAlCarrito" method="post" class="mb-2">
                                            <input type="hidden" name="idJuego" value="@juego.Id" />
                                            <input type="hidden" name="returnUrl" value="Index" />
                                            
                                            <div class="d-flex gap-2 mb-2">
                                                <div style="width: 100px;">
                                                    <label class="form-label small text-white-50 mb-1">Cantidad</label>
                                                    <input type="number" 
                                                           name="cantidad" 
                                                           class="form-control form-control-sm bg-dark text-white text-center" 
                                                           value="1" 
                                                           min="1" 
                                                           max="@juego.Stock" />
                                                </div>
                                                <div class="flex-grow-1 d-flex align-items-end">
                                                    <button type="submit" class="btn btn-outline-light w-100">
                                                        <i class="bi bi-cart-plus me-2"></i>Añadir
                                                    </button>
                                                </div>
                                            </div>
                                            <small class="text-muted d-block">Stock disponible: @juego.Stock</small>
                                        </form>
                                    }
                                    else
                                    {
                                        <a asp-controller="Carrito" asp-action="Index" class="btn w-100 mb-2 btn-ver-carrito">
                                            <i class="bi bi-cart-check me-2"></i>Ver en Carrito
                                        </a>
                                    }
                                }
                                else
                                {
                                    <button class="btn btn-secondary btn-lg w-100 mb-2" disabled>
                                        <i class="bi bi-x-circle me-2"></i>No Disponible
                                    </button>
                                }

                                <!-- Botón de Ver Detalles -->
                                <a asp-action="Details" asp-route-idjuego="@juego.Id" class="btn btn-outline-light w-100 mb-2">
                                    <i class="bi bi-eye me-2"></i>Ver Detalles
                                </a>

                                <div class="mt-2 d-flex gap-2">
                                    <a asp-action="Edit" asp-route-idjuego="@juego.Id"
                                       class="btn btn-admin-edit flex-fill">
                                        <i class="bi bi-pencil-square me-1"></i>Editar
                                    </a>
                                    <a asp-action="Delete" asp-route-idjuego="@juego.Id"
                                       class="btn btn-admin-delete flex-fill"
                                       onclick="return confirm('¿Eliminar @juego.Titulo?');">
                                        <i class="bi bi-trash3 me-1"></i>Eliminar
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Mensaje cuando no hay juegos -->
        <div class="alert alert-info d-flex align-items-center" role="alert">
            <i class="bi bi-info-circle-fill me-3" style="font-size: 2rem;"></i>
            <div>
                <h4 class="alert-heading">No hay juegos disponibles</h4>
                <p class="mb-0">No se encontraron juegos con los filtros seleccionados. Intenta con otros criterios de búsqueda.</p>
            </div>
        </div>
    }
</div>

<!-- Notificaciones Toast -->
@if (TempData["MENSAJE"] != null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
        <div class="toast show" role="alert">
            <div class="toast-header" style="background: var(--gaming-primary, #00ff88); color: #000;">
                <i class="bi bi-check-circle-fill me-2"></i>
                <strong class="me-auto">¡Éxito!</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body bg-dark text-white">
                @TempData["MENSAJE"]
            </div>
        </div>
    </div>
}

@if (TempData["INFO"] != null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
        <div class="toast show" role="alert">
            <div class="toast-header bg-info text-white">
                <i class="bi bi-info-circle-fill me-2"></i>
                <strong class="me-auto">Información</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body bg-dark text-white">
                @TempData["INFO"]
            </div>
        </div>
    </div>
}

@if (TempData["ERROR"] != null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
        <div class="toast show" role="alert">
            <div class="toast-header bg-danger text-white">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <strong class="me-auto">Error</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body bg-dark text-white">
                @TempData["ERROR"]
            </div>
        </div>
    </div>
}

<style>
    /* Card de juego con efecto hover */
    .game-card {
        transition: all 0.3s ease;
        border: 1px solid rgba(0, 255, 136, 0.2) !important;
    }   

    .game-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 40px rgba(0, 255, 136, 0.3) !important;
        border-color: var(--gaming-primary, #00ff88) !important;
    }

    /* Variables CSS */
    :root {
        --gaming-primary: #00ff88;
        --gaming-secondary: #0a84ff;
        --gaming-accent: #ff006e;
    }

    /* Botón Comprar Ahora */
    .btn-comprar-ahora {
        background: var(--gaming-primary);
        color: #000;
        font-weight: bold;
        border: none;
    }

    .btn-comprar-ahora:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 30px rgba(0, 255, 136, 0.5);
        color: #000;
    }

    /* Botón Ver en Carrito */
    .btn-ver-carrito {
        background: var(--gaming-accent);
        color: #fff;
        border: none;
        font-weight: 600;
    }

    .btn-ver-carrito:hover {
        background: #c82333;
        color: #fff;
    }

    /* Input de cantidad */
    input[type="number"].form-control {
        font-weight: 700;
    }

    /* Ocultar flechas del input number */
    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
        opacity: 1;
    }

    /* Botones de Editar/Eliminar */
    .btn-admin-edit {
        background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);
        border: 2px solid #ffc107;
        color: #000;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
    }

    .btn-admin-edit:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(255, 193, 7, 0.5);
        background: linear-gradient(135deg, #fd7e14 0%, #ffc107 100%);
        color: #000;
    }

    .btn-admin-delete {
        background: linear-gradient(135deg, #ff006e 0%, #c82333 100%);
        border: 2px solid #ff006e;
        color: white;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
    }

    .btn-admin-delete:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(255, 0, 110, 0.6);
        background: linear-gradient(135deg, #c82333 0%, #ff006e 100%);
        color: white;
    }

    /* Toast notification */
    .toast {
        border: 2px solid var(--gaming-primary);
    }
    
    /* Badge del carrito animado */
    .badge.rounded-pill {
        animation: pulse-badge 2s infinite;
    }
    
    @@keyframes pulse-badge {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }
</style>