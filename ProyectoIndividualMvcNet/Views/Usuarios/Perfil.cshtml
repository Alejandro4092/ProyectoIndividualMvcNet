@model ProyectoIndividualMvcNet.Models.Usuario

@{
    ViewData["Title"] = "Mi Perfil";
    var mensaje = ViewBag.Mensaje as string;
}

<!-- Breadcrumb -->
<div class="container mt-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-white">
                    <i class="bi bi-house-door"></i> Inicio
                </a>
            </li>
            <li class="breadcrumb-item active" style="color: var(--gaming-primary, #00d9ff);" aria-current="page">
                Mi Perfil
            </li>
        </ol>
    </nav>
</div>

<!-- Header -->
<div class="container mb-4">
    <div class="text-center">
        <h1 class="display-4 fw-bold text-white mb-2">
            <i class="bi bi-person-circle me-3" style="color: var(--gaming-primary, #00d9ff);"></i>
            Mi Perfil
        </h1>
        <p class="lead text-white-50">Administra tu información personal</p>
    </div>
</div>

<!-- Mensaje de éxito -->
@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="container mb-4">
        <div class="alert alert-success border-0 shadow-lg d-flex align-items-center" role="alert">
            <i class="bi bi-check-circle-fill me-3" style="font-size: 1.5rem;"></i>
            <div>
                <strong>¡Éxito!</strong> @mensaje
            </div>
        </div>
    </div>
}

<!-- Contenido Principal -->
<div class="container mb-5">
    <div class="row">
        <!-- Columna izquierda: Avatar y estadísticas -->
        <div class="col-lg-4">
            <!-- Card de Avatar -->
            <div class="card bg-dark border-0 shadow-lg mb-4">
                <div class="card-body text-center p-4">
                    <div class="mb-4">
                        @if (!string.IsNullOrEmpty(Model.Imagen))
                        {
                            <img src="@Model.Imagen" alt="Avatar" class="rounded-circle shadow-lg" style="width: 150px; height: 150px; object-fit: cover; border: 4px solid var(--gaming-primary, #00d9ff);">
                        }
                        else
                        {
                            <div class="rounded-circle d-inline-flex align-items-center justify-content-center shadow-lg" style="width: 150px; height: 150px; background: linear-gradient(135deg, var(--gaming-primary, #00d9ff) 0%, var(--gaming-secondary, #8b5cf6) 100%); border: 4px solid var(--gaming-primary, #00d9ff);">
                                <i class="bi bi-person-fill text-white" style="font-size: 4rem;"></i>
                            </div>
                        }
                    </div>
                    <h3 class="text-white fw-bold mb-2">@Model.Nombre</h3>
                    <p class="text-white-50 mb-3">
                        <i class="bi bi-envelope me-2"></i>@Model.Email
                    </p>
                </div>
            </div>
            <!-- Información adicional -->
            <div class="card bg-dark border-0 shadow-lg mb-4">
                <div class="card-header border-0 py-3" style="background: linear-gradient(90deg, var(--gaming-primary, #00d9ff) 0%, transparent 100%);">
                    <h5 class="mb-0 text-white">
                        <i class="bi bi-info-circle me-2"></i>Información de Cuenta
                    </h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">
                            <i class="bi bi-hash me-1"></i>ID de Usuario
                        </small>
                        <strong class="text-white fs-5">#@Model.IdUsuario.ToString("D5")</strong>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">
                            <i class="bi bi-calendar-event me-1"></i>Miembro desde
                        </small>
                
                    </div>
                    <div>
                        <small class="text-muted d-block mb-1">
                            <i class="bi bi-clock me-1"></i>Estado
                        </small>
                        <span class="badge bg-success fs-6 px-3 py-2">
                            <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>Activo
                        </span>
                    </div>
                </div>
            </div>
            <!-- Acciones rápidas -->
            <div class="card bg-dark border-0 shadow-lg">
                <div class="card-body">
                    <h6 class="text-white mb-3">
                        <i class="bi bi-lightning-fill me-2" style="color: var(--gaming-accent, #ff006e);"></i>
                        Acciones Rápidas
                    </h6>
                    <div class="d-grid gap-2">
                        <a asp-controller="Juegos" asp-action="MisCompras" class="btn btn-outline-light">
                            <i class="bi bi-bag-check me-2"></i>Mis Pedidos
                        </a>
                        <a asp-controller="Juegos" asp-action="Index" class="btn btn-outline-light">
                            <i class="bi bi-controller me-2"></i>Catálogo
                        </a>
                        <a asp-controller="Carrito" asp-action="Index" class="btn btn-outline-light">
                            <i class="bi bi-cart3 me-2"></i>Mi Carrito
                        </a>
                        <a asp-controller="Usuarios" asp-action="Logout" class="btn btn-outline-danger">
                            <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <!-- Columna derecha: Formulario de edición -->
        <div class="col-lg-8">
            <div class="card bg-dark border-0 shadow-lg">
                <div class="card-header border-0 py-4" style="background: linear-gradient(90deg, var(--gaming-secondary, #8b5cf6) 0%, transparent 100%);">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-pencil-square me-2"></i>Editar Información Personal
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Perfil" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="IdUsuario" />
                        <input type="hidden" asp-for="Rol" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 mb-4" role="alert"></div>
                        <!-- Nombre -->
                        <div class="mb-4">
                            <label asp-for="Nombre" class="form-label text-white fw-bold">
                                <i class="bi bi-person me-2"></i>Nombre Completo
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Nombre" class="form-control form-control-lg bg-dark text-white border-secondary" placeholder="Tu nombre completo" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Email" class="form-label text-white fw-bold">
                                <i class="bi bi-envelope me-2"></i>Correo Electrónico
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Email" type="email" class="form-control form-control-lg bg-dark text-white border-secondary" placeholder="tu@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label for="avatarFile" class="form-label text-white fw-bold">
                                <i class="bi bi-image me-2"></i>Cambiar Avatar
                            </label>
                            <input type="file" name="avatarFile" id="avatarFile" class="form-control bg-dark text-white border-secondary" accept="image/*" />
                            <small class="text-white-50">Formatos permitidos: jpg, jpeg, png, gif, webp</small>
                        </div>
                        <div class="row mt-5">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <button type="submit" class="btn btn-lg w-100 shadow-lg" style="background: var(--gaming-primary, #00d9ff); color: #000; font-weight: bold;">
                                    <i class="bi bi-check-circle me-2"></i>Guardar Cambios
                                </button>
                            </div>
                            <div class="col-md-6">
                                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-lg w-100">
                                    <i class="bi bi-x-circle me-2"></i>Cancelar
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <!-- Consejos de seguridad -->
            <div class="card bg-dark border-0 shadow-lg mt-4" style="border-left: 4px solid var(--gaming-accent, #ff006e) !important;">
                <div class="card-body">
                    <h6 class="text-white mb-3">
                        <i class="bi bi-shield-lock-fill me-2" style="color: var(--gaming-accent, #ff006e);"></i>
                        Consejos de Seguridad
                    </h6>
                    <ul class="text-white-50 small mb-0">
                        <li class="mb-2">Usa una contraseña fuerte con letras, números y símbolos</li>
                        <li class="mb-2">No compartas tu contraseña con nadie</li>
                        <li class="mb-2">Verifica que tu correo electrónico sea válido y accesible</li>
                        <li class="mb-2">Mantén tu información actualizada para recibir notificaciones</li>
                        <li>Si sospechas actividad inusual, cambia tu contraseña inmediatamente</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    .form-control:focus,
    .form-select:focus {
        background-color: #1a1a2e !important;
        color: white !important;
        border-color: var(--gaming-primary, #00d9ff) !important;
        box-shadow: 0 0 0 0.25rem rgba(0, 217, 255, 0.25) !important;
    }

    :root {
        --gaming-primary: #00d9ff;
        --gaming-secondary: #8b5cf6;
        --gaming-accent: #ff006e;
    }
</style>