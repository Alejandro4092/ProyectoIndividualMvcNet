@model List<ProyectoIndividualMvcNet.Models.Usuario>

@{
    ViewData["Title"] = "Panel de Administración";
    var mensaje = TempData["Mensaje"] as string;
    var resenas = ViewBag.Resenas as List<ProyectoIndividualMvcNet.Models.Resena> ?? new List<ProyectoIndividualMvcNet.Models.Resena>();
}

<!-- Breadcrumb -->
<div class="container mt-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-white">
                    <i class="bi bi-house-door"></i> Inicio
                </a>
            </li>
            <li class="breadcrumb-item active" style="color: var(--gaming-primary, #00d9ff);" aria-current="page">
                Panel de Administración
            </li>
        </ol>
    </nav>
</div>

<!-- Header -->
<div class="container mb-4">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="display-4 fw-bold text-white mb-2">
                <i class="bi bi-shield-lock-fill me-3" style="color: var(--gaming-primary, #00d9ff);"></i>
                Panel de Administración
            </h1>
            <p class="lead text-white-50">Gestión completa del sistema</p>
        </div>
        <div class="col-md-4 text-md-end">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-lg">
                <i class="bi bi-arrow-left me-2"></i>Volver
            </a>
        </div>
    </div>
</div>

<!-- Mensaje de éxito -->
@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="container mb-4">
        <div class="alert alert-success border-0 shadow-lg d-flex align-items-center" role="alert">
            <i class="bi bi-check-circle-fill me-3" style="font-size: 1.5rem;"></i>
            <div>
                <strong>¡Éxito!</strong> @mensaje
            </div>
        </div>
    </div>
}

<!-- Estadísticas -->
<div class="container mb-4">
    <div class="row g-4">
        <div class="col-md-3">
            <div class="card bg-dark border-0 shadow-lg">
                <div class="card-body text-center p-4">
                    <i class="bi bi-people-fill mb-3" style="font-size: 3rem; color: var(--gaming-primary, #00d9ff);"></i>
                    <h3 class="text-white fw-bold mb-2">@Model.Count</h3>
                    <p class="text-white-50 mb-0">Total Usuarios</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-dark border-0 shadow-lg">
                <div class="card-body text-center p-4">
                    <i class="bi bi-person-check-fill mb-3" style="font-size: 3rem; color: var(--gaming-secondary, #8b5cf6);"></i>
                    <h3 class="text-white fw-bold mb-2">@Model.Count(u => u.RolId == 0)</h3>
                    <p class="text-white-50 mb-0">Usuarios Activos</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-dark border-0 shadow-lg">
                <div class="card-body text-center p-4">
                    <i class="bi bi-shield-fill-check mb-3" style="font-size: 3rem; color: var(--gaming-accent, #ff006e);"></i>
                    <h3 class="text-white fw-bold mb-2">@Model.Count(u => u.RolId == 1)</h3>
                    <p class="text-white-50 mb-0">Administradores</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-dark border-0 shadow-lg">
                <div class="card-body text-center p-4">
                    <i class="bi bi-chat-dots-fill mb-3" style="font-size: 3rem; color: #ffc107;"></i>
                    <h3 class="text-white fw-bold mb-2">@resenas.Count</h3>
                    <p class="text-white-50 mb-0">Reseñas Totales</p>
                </div>
            </div>
        </div>
        </div>
</div>

<!-- Tabs de navegación -->
<div class="container mb-4">
    <ul class="nav nav-pills nav-fill" id="adminTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="usuarios-tab" data-bs-toggle="pill" data-bs-target="#usuarios" type="button" role="tab">
                <i class="bi bi-people me-2"></i>Gestión de Usuarios
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="resenas-tab" data-bs-toggle="pill" data-bs-target="#resenas" type="button" role="tab">
                <i class="bi bi-shield-check me-2"></i>Moderación de Reseñas
            </button>
        </li>
    </ul>
</div>

<!-- Contenido de los tabs -->
<div class="container mb-5">
    <div class="tab-content" id="adminTabsContent">
        <!-- Tab: Usuarios -->
        <div class="tab-pane fade show active" id="usuarios" role="tabpanel">
            <div class="card bg-dark border-0 shadow-lg">
                <div class="card-header border-0 py-4" style="background: linear-gradient(90deg, var(--gaming-primary, #00d9ff) 0%, transparent 100%);">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <h4 class="mb-0 text-white">
                                <i class="bi bi-list-ul me-2"></i>Lista de Usuarios
                            </h4>
                        </div>
                        <div class="col-md-6 text-md-end mt-3 mt-md-0">
                            <div class="input-group">
                                <input type="text" id="searchInput" class="form-control bg-dark text-white border-secondary" placeholder="Buscar usuario...">
                                <button class="btn btn-outline-light" type="button">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-dark table-hover mb-0">
                                <thead>
                                    <tr style="border-bottom: 2px solid var(--gaming-primary, #00d9ff);">
                                        <th class="text-center" style="width: 80px;">
                                            <i class="bi bi-image"></i>
                                        </th>
                                        <th>
                                            <i class="bi bi-hash me-1"></i>ID
                                        </th>
                                        <th>
                                            <i class="bi bi-person me-1"></i>Nombre
                                        </th>
                                        <th>
                                            <i class="bi bi-envelope me-1"></i>Email
                                        </th>
                                        <th>
                                            <i class="bi bi-shield me-1"></i>Rol
                                        </th>
                                        <th class="text-center" style="width: 200px;">
                                            <i class="bi bi-gear me-1"></i>Acciones
                                        </th>
                                    </tr>
                                </thead>
                                <tbody id="userTableBody">
                                    @foreach (var usuario in Model)
                                    {
                                        <tr class="user-row">
                                            <td class="text-center align-middle">
                                                @if (!string.IsNullOrEmpty(usuario.Imagen))
                                                {
                                                    <img src="@usuario.Imagen" alt="Avatar" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover; border: 2px solid var(--gaming-primary, #00d9ff);">
                                                }
                                                else
                                                {
                                                    <div class="rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: linear-gradient(135deg, var(--gaming-primary, #00d9ff) 0%, var(--gaming-secondary, #8b5cf6) 100%); border: 2px solid var(--gaming-primary, #00d9ff);">
                                                        <i class="bi bi-person-fill text-white"></i>
                                                    </div>
                                                }
                                            </td>
                                            <td class="align-middle">
                                                <strong class="text-white">#@usuario.IdUsuario.ToString("D5")</strong>
                                            </td>
                                            <td class="align-middle user-name">
                                                <strong class="text-white">@usuario.Nombre</strong>
                                            </td>
                                            <td class="align-middle user-email">
                                                <span class="text-white-50">@usuario.Email</span>
                                            </td>
                                            <td class="align-middle">
                                                @if (usuario.RolId == 1)
                                                {
                                                    <span class="badge bg-danger">
                                                        <i class="bi bi-shield-fill-exclamation me-1"></i>Admin
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-info">
                                                        <i class="bi bi-person-fill me-1"></i>Usuario
                                                    </span>
                                                }
                                            </td>
                                            <td class="text-center align-middle">
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Perfil" asp-route-idUsuario="@usuario.IdUsuario" class="btn btn-sm btn-outline-primary" title="Ver Perfil">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                    <button class="btn btn-sm btn-outline-danger" title="Eliminar" 
                                                            onclick="confirmarEliminar(@usuario.IdUsuario, '@usuario.Nombre')">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox text-white-50 mb-3" style="font-size: 4rem;"></i>
                            <h4 class="text-white mb-2">No hay usuarios registrados</h4>
                            <p class="text-white-50">La lista de usuarios está vacía.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Tab: Moderación de Reseñas -->
        <div class="tab-pane fade" id="resenas" role="tabpanel">
            <div class="card bg-dark border-0 shadow-lg">
                <div class="card-header border-0 py-4" style="background: linear-gradient(90deg, #ffc107 0%, #fd7e14 100%); color: #000;">
                    <h4 class="mb-0">
                        <i class="bi bi-shield-check me-2"></i>Moderación de Reseñas
                    </h4>
                    <small>Gestiona el contenido generado por usuarios</small>
                </div>
                <div class="card-body">
                    @if (resenas != null && resenas.Count > 0)
                    {
                        <div class="mb-3">
                            <input type="text" id="searchResenas" class="form-control bg-dark text-white border-secondary" placeholder="Buscar en reseñas...">
                        </div>
                        <div class="table-responsive">
                            <table class="table table-dark table-hover mb-0">
                                <thead>
                                    <tr style="border-bottom: 2px solid #ffc107;">
                                        <th>
                                            <i class="bi bi-person me-2"></i>Usuario
                                        </th>
                                        <th>
                                            <i class="bi bi-controller me-2"></i>Juego
                                        </th>
                                        <th>
                                            <i class="bi bi-star-fill me-2"></i>Nota
                                        </th>
                                        <th>
                                            <i class="bi bi-chat-text me-2"></i>Comentario
                                        </th>
                                        <th>
                                            <i class="bi bi-calendar me-2"></i>Fecha
                                        </th>
                                        <th class="text-center">
                                            <i class="bi bi-gear me-2"></i>Acción
                                        </th>
                                    </tr>
                                </thead>
                                <tbody id="resenasTableBody">
                                    @foreach (var res in resenas)
                                    {
                                        <tr class="resena-row">
                                            <td>
                                                <span class="user-badge">
                                                    <i class="bi bi-person-circle me-1"></i>
                                                    @(res.Usuario?.Nombre ?? $"Usuario #{res.UsuarioId}")
                                                </span>
                                            </td>
                                            <td class="juego-title">
                                                <span class="game-badge">
                                                    <i class="bi bi-joystick me-1"></i>
                                                    @(res.Juego?.Titulo ?? $"Juego #{res.JuegoId}")
                                                </span>
                                            </td>
                                            <td>
                                                <span class="nota-badge nota-@res.Nota">
                                                    @res.Nota <i class="bi bi-star-fill ms-1"></i>
                                                </span>
                                            </td>
                                            <td class="comentario-cell resena-comentario">
                                                <span class="comentario-text" title="@res.Comentario">
                                                    <i class="bi bi-chat-quote me-1"></i>
                                                    @res.Comentario
                                                </span>
                                            </td>
                                            <td>
                                                <small class="text-muted">
                                                    @res.Fecha.ToString("dd/MM/yyyy HH:mm")
                                                </small>
                                            </td>
                                            <td class="text-center">
                                                <form asp-controller="Juegos" asp-action="BorrarResena" method="post" class="d-inline" 
                                                      onsubmit="return confirm('¿Estás seguro de eliminar esta reseña?');">
                                                    <input type="hidden" name="idResena" value="@res.Id" />
                                                    <button type="submit" class="btn btn-eliminar btn-sm">
                                                        <i class="bi bi-trash3 me-1"></i>Eliminar
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning border-0 shadow-sm d-flex align-items-center" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-3" style="font-size: 1.5rem;"></i>
                            <div>
                                <strong>Sin reseñas</strong> No hay reseñas registradas en el sistema.
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Búsqueda en tiempo real - Usuarios
        document.getElementById('searchInput')?.addEventListener('keyup', function() {
            const searchTerm = this.value.toLowerCase();
            const rows = document.querySelectorAll('#userTableBody .user-row');

            rows.forEach(row => {
                const name = row.querySelector('.user-name')?.textContent.toLowerCase() || '';
                const email = row.querySelector('.user-email')?.textContent.toLowerCase() || '';

                if (name.includes(searchTerm) || email.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });

        // Búsqueda en tiempo real - Reseñas
        document.getElementById('searchResenas')?.addEventListener('keyup', function() {
            const searchTerm = this.value.toLowerCase();
            const rows = document.querySelectorAll('#resenasTableBody .resena-row');

            rows.forEach(row => {
                const juego = row.querySelector('.juego-title')?.textContent.toLowerCase() || '';
                const comentario = row.querySelector('.resena-comentario')?.textContent.toLowerCase() || '';

                if (juego.includes(searchTerm) || comentario.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });

        // Confirmación de eliminación de usuario
        function confirmarEliminar(idUsuario, nombreUsuario) {
            if (confirm(`¿Estás seguro de eliminar al usuario "${nombreUsuario}"?\n\nEsta acción no se puede deshacer.`)) {
                window.location.href = `/Usuarios/DeleteUsuario?idUsuario=${idUsuario}`;
            }
        }
    </script>
}

<style>
    .table-dark tbody tr:hover {
        background-color: rgba(0, 217, 255, 0.1);
    }

    .form-control:focus {
        background-color: #1a1a2e !important;
        color: white !important;
        border-color: var(--gaming-primary, #00d9ff) !important;
        box-shadow: 0 0 0 0.25rem rgba(0, 217, 255, 0.25) !important;
    }

    :root {
        --gaming-primary: #00d9ff;
        --gaming-secondary: #8b5cf6;
        --gaming-accent: #ff006e;
    }

    /* Estilos para tabs */
    .nav-pills .nav-link {
        color: #fff;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        margin: 0 5px;
        transition: all 0.3s ease;
        font-weight: 600;
    }

    .nav-pills .nav-link:hover {
        background: rgba(0, 217, 255, 0.2);
        border-color: var(--gaming-primary);
        transform: translateY(-2px);
    }

    .nav-pills .nav-link.active {
        background: linear-gradient(135deg, var(--gaming-primary) 0%, var(--gaming-secondary) 100%);
        color: #000;
        font-weight: 700;
        border: none;
        box-shadow: 0 4px 15px rgba(0, 217, 255, 0.4);
    }

    /* Estilos de badges para reseñas */
    .user-badge {
        display: inline-flex;
        align-items: center;
        background: rgba(255, 193, 7, 0.2);
        color: #ffc107;
        padding: 6px 12px;
        border-radius: 15px;
        font-weight: 600;
        font-size: 0.9rem;
        border: 1px solid rgba(255, 193, 7, 0.3);
    }

    .game-badge {
        display: inline-flex;
        align-items: center;
        background: rgba(10, 132, 255, 0.2);
        color: var(--gaming-secondary);
        padding: 6px 12px;
        border-radius: 15px;
        font-weight: 600;
        font-size: 0.9rem;
        border: 1px solid rgba(10, 132, 255, 0.3);
    }

    .nota-badge {
        display: inline-flex;
        align-items: center;
        padding: 6px 14px;
        border-radius: 20px;
        font-weight: 700;
        font-size: 0.95rem;
        white-space: nowrap;
    }

    .nota-1, .nota-2 {
        background: rgba(220, 53, 69, 0.2);
        color: #dc3545;
        border: 2px solid #dc3545;
    }

    .nota-3 {
        background: rgba(255, 193, 7, 0.2);
        color: #ffc107;
        border: 2px solid #ffc107;
    }

    .nota-4, .nota-5 {
        background: rgba(25, 135, 84, 0.2);
        color: #20c997;
        border: 2px solid #20c997;
    }

    .comentario-cell {
        max-width: 300px;
    }

    .comentario-text {
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: rgba(255, 255, 255, 0.7);
        font-style: italic;
    }

    .btn-eliminar {
        background: linear-gradient(135deg, var(--gaming-accent) 0%, #c82333 100%);
        color: white;
        border: 2px solid var(--gaming-accent);
        font-weight: 700;
        padding: 6px 16px;
        border-radius: 6px;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
    }

    .btn-eliminar:hover {
        transform: scale(1.05);
        box-shadow: 0 6px 15px rgba(255, 0, 110, 0.5);
        background: linear-gradient(135deg, #c82333 0%, var(--gaming-accent) 100%);
        color: white;
    }

    /* Animación de tabs */
    .tab-pane {
        animation: fadeIn 0.5s ease-in;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>