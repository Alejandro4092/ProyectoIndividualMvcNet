@model List<ProyectoIndividualMvcNet.Models.Usuario>

@{
    ViewData["Title"] = "Panel de Administración - Usuarios";
    var mensaje = TempData["Mensaje"] as string;
}

<!-- Breadcrumb -->
<div class="container mt-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-white">
                    <i class="bi bi-house-door"></i> Inicio
                </a>
            </li>
            <li class="breadcrumb-item active" style="color: var(--gaming-primary, #00d9ff);" aria-current="page">
                Administración de Usuarios
            </li>
        </ol>
    </nav>
</div>

<!-- Header -->
<div class="container mb-4">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="display-4 fw-bold text-white mb-2">
                <i class="bi bi-shield-lock-fill me-3" style="color: var(--gaming-primary, #00d9ff);"></i>
                Panel de Administración
            </h1>
            <p class="lead text-white-50">Gestión de usuarios del sistema</p>
        </div>
        <div class="col-md-4 text-md-end">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-lg">
                <i class="bi bi-arrow-left me-2"></i>Volver al Inicio
            </a>
        </div>
    </div>
</div>

<!-- Mensaje de éxito -->
@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="container mb-4">
        <div class="alert alert-success border-0 shadow-lg d-flex align-items-center" role="alert">
            <i class="bi bi-check-circle-fill me-3" style="font-size: 1.5rem;"></i>
            <div>
                <strong>¡Éxito!</strong> @mensaje
            </div>
        </div>
    </div>
}

<!-- Estadísticas -->
<div class="container mb-4">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card bg-dark border-0 shadow-lg">
                <div class="card-body text-center p-4">
                    <i class="bi bi-people-fill mb-3" style="font-size: 3rem; color: var(--gaming-primary, #00d9ff);"></i>
                    <h3 class="text-white fw-bold mb-2">@Model.Count</h3>
                    <p class="text-white-50 mb-0">Total de Usuarios</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark border-0 shadow-lg">
                <div class="card-body text-center p-4">
                    <i class="bi bi-person-check-fill mb-3" style="font-size: 3rem; color: var(--gaming-secondary, #8b5cf6);"></i>
                    <h3 class="text-white fw-bold mb-2">@Model.Count</h3>
                    <p class="text-white-50 mb-0">Usuarios Activos</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark border-0 shadow-lg">
                <div class="card-body text-center p-4">
                    <i class="bi bi-shield-fill-check mb-3" style="font-size: 3rem; color: var(--gaming-accent, #ff006e);"></i>
                    <h3 class="text-white fw-bold mb-2">0</h3>
                    <p class="text-white-50 mb-0">Administradores</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabla de Usuarios -->
<div class="container mb-5">
    <div class="card bg-dark border-0 shadow-lg">
        <div class="card-header border-0 py-4" style="background: linear-gradient(90deg, var(--gaming-primary, #00d9ff) 0%, transparent 100%);">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-list-ul me-2"></i>Lista de Usuarios
                    </h4>
                </div>
                <div class="col-md-6 text-md-end mt-3 mt-md-0">
                    <div class="input-group">
                        <input type="text" id="searchInput" class="form-control bg-dark text-white border-secondary" placeholder="Buscar usuario...">
                        <button class="btn btn-outline-light" type="button">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-dark table-hover mb-0">
                        <thead>
                            <tr style="border-bottom: 2px solid var(--gaming-primary, #00d9ff);">
                                <th class="text-center" style="width: 80px;">
                                    <i class="bi bi-image"></i>
                                </th>
                                <th>
                                    <i class="bi bi-hash me-1"></i>ID
                                </th>
                                <th>
                                    <i class="bi bi-person me-1"></i>Nombre
                                </th>
                                <th>
                                    <i class="bi bi-envelope me-1"></i>Email
                                </th>
                                <th class="text-center" style="width: 200px;">
                                    <i class="bi bi-gear me-1"></i>Acciones
                                </th>
                            </tr>
                        </thead>
                        <tbody id="userTableBody">
                            @foreach (var usuario in Model)
                            {
                                <tr class="user-row">
                                    <td class="text-center align-middle">
                                        @if (!string.IsNullOrEmpty(usuario.Imagen))
                                        {
                                            <img src="@usuario.Imagen" alt="Avatar" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover; border: 2px solid var(--gaming-primary, #00d9ff);">
                                        }
                                        else
                                        {
                                            <div class="rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: linear-gradient(135deg, var(--gaming-primary, #00d9ff) 0%, var(--gaming-secondary, #8b5cf6) 100%); border: 2px solid var(--gaming-primary, #00d9ff);">
                                                <i class="bi bi-person-fill text-white"></i>
                                            </div>
                                        }
                                    </td>
                                    <td class="align-middle">
                                        <strong class="text-white">#@usuario.IdUsuario.ToString("D5")</strong>
                                    </td>
                                    <td class="align-middle user-name">
                                        <strong class="text-white">@usuario.Nombre</strong>
                                    </td>
                                    <td class="align-middle user-email">
                                        <span class="text-white-50">@usuario.Email</span>
                                    </td>
                                    <td class="text-center align-middle">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Perfil" asp-route-idUsuario="@usuario.IdUsuario" class="btn btn-sm btn-outline-primary" title="Ver Perfil">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="DeleteUsuario" asp-route-idUsuario="@usuario.IdUsuario" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-white-50 mb-3" style="font-size: 4rem;"></i>
                    <h4 class="text-white mb-2">No hay usuarios registrados</h4>
                    <p class="text-white-50">La lista de usuarios está vacía.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Búsqueda en tiempo real
        document.getElementById('searchInput').addEventListener('keyup', function() {
            const searchTerm = this.value.toLowerCase();
            const rows = document.querySelectorAll('#userTableBody .user-row');

            rows.forEach(row => {
                const name = row.querySelector('.user-name').textContent.toLowerCase();
                const email = row.querySelector('.user-email').textContent.toLowerCase();

                if (name.includes(searchTerm) || email.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
}

<style>
    .table-dark tbody tr:hover {
        background-color: rgba(0, 217, 255, 0.1);
    }

    .form-control:focus {
        background-color: #1a1a2e !important;
        color: white !important;
        border-color: var(--gaming-primary, #00d9ff) !important;
        box-shadow: 0 0 0 0.25rem rgba(0, 217, 255, 0.25) !important;
    }

    :root {
        --gaming-primary: #00d9ff;
        --gaming-secondary: #8b5cf6;
        --gaming-accent: #ff006e;
    }
</style>