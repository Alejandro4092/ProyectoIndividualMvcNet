@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "_LayoutAuth";
    var mensaje = ViewData["MENSAJE"] as string;
}

<!-- Header -->
<div class="container mb-4">
    <div class="text-center">
        <h1 class="display-4 fw-bold text-white mb-2">
            <i class="bi bi-box-arrow-in-right me-3" style="color: var(--gaming-primary, #00ff88);"></i>
            Bienvenido de Nuevo
        </h1>
        <p class="lead text-white-50">Inicia sesión para acceder a tu cuenta de GameStore</p>
    </div>
</div>

<!-- Formulario de Login -->
<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <!-- Mensaje de error -->
            @if (!string.IsNullOrEmpty(mensaje))
            {
                <div class="alert alert-danger alert-dismissible fade show border-0 shadow-lg mb-4" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill me-3 fs-4"></i>
                        <div>
                            <strong>Error de autenticación</strong>
                            <p class="mb-0 mt-1">@mensaje</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- Card Principal -->
            <div class="card bg-dark border-0 shadow-lg">
                <div class="card-header border-0 py-4" style="background: linear-gradient(90deg, var(--gaming-secondary, #0a84ff) 0%, transparent 100%);">
                    <h4 class="mb-0 text-white">
                        <i class="bi bi-shield-lock me-2"></i>Acceso a tu Cuenta
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Login" method="post">
                        <!-- Email -->
                        <div class="mb-4">
                            <label for="email" class="form-label text-white fw-bold">
                                <i class="bi bi-envelope me-2"></i>Correo Electrónico
                                <span class="text-danger">*</span>
                            </label>
                            <input type="email"
                                   name="email"
                                   id="email"
                                   class="form-control form-control-lg bg-dark text-white border-secondary"
                                   placeholder="ejemplo@correo.com"
                                   required
                                   autofocus />
                        </div>

                        <!-- Password -->
                        <div class="mb-4">
                            <label for="password" class="form-label text-white fw-bold">
                                <i class="bi bi-key me-2"></i>Contraseña
                                <span class="text-danger">*</span>
                            </label>
                            <div class="input-group input-group-lg">
                                <input type="password"
                                       name="password"
                                       id="password"
                                       class="form-control bg-dark text-white border-secondary"
                                       placeholder="••••••••"
                                       required />
                                <button class="btn btn-outline-secondary"
                                        type="button"
                                        id="togglePassword">
                                    <i class="bi bi-eye" id="eyeIcon"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Recordar / Olvidé contraseña -->
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="recordar"
                                       style="width: 1.2rem; height: 1.2rem; cursor: pointer;">
                                <label class="form-check-label text-white ms-1" for="recordar">
                                    Recordarme
                                </label>
                            </div>
                            <a href="#" class="text-decoration-none" style="color: var(--gaming-primary, #00ff88);">
                                ¿Olvidaste tu contraseña?
                            </a>
                        </div>

                        <!-- Botón de Login -->
                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-lg shadow-lg py-3" style="background: var(--gaming-secondary, #0a84ff); color: #fff; font-weight: bold;">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesión
                            </button>
                        </div>

                        <!-- Separador -->
                        <div class="position-relative my-4">
                            <hr class="border-secondary">
                            <span class="position-absolute top-50 start-50 translate-middle bg-dark px-3 text-muted">
                                o inicia sesión con
                            </span>
                        </div>

                        <!-- Link a Registro -->
                        <div class="text-center">
                            <p class="text-muted mb-0">
                                ¿No tienes una cuenta?
                                <a asp-action="Register" class="text-decoration-none fw-bold" style="color: var(--gaming-primary, #00ff88);">
                                    Regístrate aquí
                                </a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Información de Seguridad -->
            <div class="card bg-dark border-0 shadow mt-4">
                <div class="card-body p-4">
                    <div class="text-center mb-3">
                        <i class="bi bi-shield-check" style="font-size: 3rem; color: var(--gaming-primary, #00ff88);"></i>
                    </div>
                    <h6 class="text-white text-center mb-3">
                        Tu seguridad es nuestra prioridad
                    </h6>
                    <div class="row g-3 text-light small">
                        <div class="col-6">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-check-circle-fill me-2 mt-1" style="color: var(--gaming-primary, #00ff88);"></i>
                                <span>Conexión encriptada SSL</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-check-circle-fill me-2 mt-1" style="color: var(--gaming-primary, #00ff88);"></i>
                                <span>Contraseñas cifradas</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-check-circle-fill me-2 mt-1" style="color: var(--gaming-primary, #00ff88);"></i>
                                <span>Autenticación segura</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-check-circle-fill me-2 mt-1" style="color: var(--gaming-primary, #00ff88);"></i>
                                <span>Datos protegidos</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Toggle mostrar/ocultar contraseña
        document.getElementById('togglePassword').addEventListener('click', function () {
            const passwordInput = document.getElementById('password');
            const eyeIcon = document.getElementById('eyeIcon');

            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                eyeIcon.classList.remove('bi-eye');
                eyeIcon.classList.add('bi-eye-slash');
            } else {
                passwordInput.type = 'password';
                eyeIcon.classList.remove('bi-eye-slash');
                eyeIcon.classList.add('bi-eye');
            }
        });

        // Auto-focus en email si hay error
        @if (!string.IsNullOrEmpty(mensaje))
        {
                    <text>
                    document.getElementById('email').focus();
                    </text>
        }

        // Animación de shake en error
        @if (!string.IsNullOrEmpty(mensaje))
        {
                    <text>
                    const card = document.querySelector('.card');
                    card.style.animation = 'shake 0.5s';
                    setTimeout(() => {
                        card.style.animation = '';
                    }, 500);
                    </text>
        }
    </script>
}

<style>
    .form-control:focus,
    .form-select:focus {
        background-color: #1a1a2e !important;
        color: white !important;
        border-color: var(--gaming-secondary, #0a84ff) !important;
        box-shadow: 0 0 0 0.25rem rgba(10, 132, 255, 0.25) !important;
    }

    .form-check-input:checked {
        background-color: var(--gaming-primary, #00ff88);
        border-color: var(--gaming-primary, #00ff88);
    }

    .form-check-input:focus {
        border-color: var(--gaming-primary, #00ff88);
        box-shadow: 0 0 0 0.25rem rgba(0, 255, 136, 0.25);
    }

    .btn-outline-light:hover {
        background-color: var(--gaming-primary, #00ff88);
        border-color: var(--gaming-primary, #00ff88);
        color: #000;
    }

    /* Variables CSS fallback */
    :root {
        --gaming-primary: #00ff88;
        --gaming-secondary: #0a84ff;
        --gaming-accent: #ff006e;
    }

    /* Animación para el botón de submit */
    button[type="submit"]:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 30px rgba(10, 132, 255, 0.4) !important;
        transition: all 0.3s ease;
    }

    /* Estilo para inputs en focus */
    .input-group:focus-within {
        box-shadow: 0 0 20px rgba(10, 132, 255, 0.3);
        border-radius: 0.375rem;
    }

    /* Animación de shake para errores */
    @@keyframes shake {
        0%, 100% {
            transform: translateX(0);
        }

        10%, 30%, 50%, 70%, 90% {
            transform: translateX(-10px);
        }

        20%, 40%, 60%, 80% {
            transform: translateX(10px);
        }
    }

    /* Sticky sidebar */
    .sticky-top {
        position: sticky;
        top: 100px;
        z-index: 10;
    }

    /* Efecto hover en cards de beneficios */
    .card-body > div > div:hover {
        transform: translateX(5px);
        transition: all 0.3s ease;
    }
</style>