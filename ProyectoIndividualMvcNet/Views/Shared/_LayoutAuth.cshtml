<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GameStore</title>

    <!-- Bootstrap 5.3 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProyectoIndividualMvcNet.styles.css" asp-append-version="true" />

    <style>
        :root {
            --gaming-primary: #00ff88;
            --gaming-secondary: #0a84ff;
            --gaming-accent: #ff006e;
            --gaming-dark: #0d1117;
            --gaming-darker: #010409;
            --gaming-gray: #161b22;
        }

        body {
            font-family: 'Rajdhani', sans-serif;
            background: linear-gradient(135deg, var(--gaming-darker) 0%, var(--gaming-dark) 50%, #1a1f2e 100%);
            background-attachment: fixed;
            color: #e6edf3;
            min-height: 100vh;
            padding: 0;
            margin: 0;
        }

        h1, h2, h3, h4, h5, h6, .display-1, .display-2, .display-3, .display-4 {
            font-family: 'Orbitron', sans-serif;
        }

        /* Scrollbar personalizado */
        ::-webkit-scrollbar {
            width: 12px;
        }

        ::-webkit-scrollbar-track {
            background: var(--gaming-darker);
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, var(--gaming-primary), var(--gaming-secondary));
            border-radius: 6px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: var(--gaming-primary);
            }

        /* Contenedor principal responsive */
        .auth-wrapper {
            min-height: 100vh;
            padding-top: 80px; /* Espacio para el logo */
            padding-bottom: 20px;
        }

        /* Animación de carga */
        .page-transition {
            animation: fadeIn 0.5s ease-in;
            width: 100%;
            padding: 20px 0;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Logo flotante responsive */
        .auth-logo {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(13, 17, 23, 0.95);
            backdrop-filter: blur(10px);
            padding: 15px 20px;
            z-index: 1000;
            border-bottom: 2px solid var(--gaming-primary);
            box-shadow: 0 2px 20px rgba(0, 255, 136, 0.1);
        }

            .auth-logo a {
                font-family: 'Orbitron', sans-serif;
                font-weight: 900;
                font-size: 1.5rem;
                background: linear-gradient(45deg, var(--gaming-primary), var(--gaming-secondary));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                text-transform: uppercase;
                letter-spacing: 2px;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                transition: all 0.3s ease;
            }

                .auth-logo a:hover {
                    filter: brightness(1.2);
                    transform: scale(1.05);
                }

            .auth-logo i {
                background: linear-gradient(45deg, var(--gaming-primary), var(--gaming-secondary));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                margin-right: 8px;
            }

        /* Responsive para móviles */
        @@media (max-width: 768px) {
            .auth-logo a {
                font-size: 1.2rem;
                letter-spacing: 1px;
            }

            .auth-wrapper {
                padding-top: 70px;
            }

            .page-transition {
                padding: 10px 0;
            }
            /* Ajustar tamaño de títulos en móvil */
            .display-4 {
                font-size: 2rem !important;
            }

            .lead {
                font-size: 1rem !important;
            }
        }

        @@media (max-width: 576px) {
            .auth-logo {
                padding: 12px 15px;
            }

                .auth-logo a {
                    font-size: 1rem;
                }

                .auth-logo i {
                    margin-right: 5px;
                    font-size: 1rem;
                }

            .auth-wrapper {
                padding-top: 60px;
            }
        }

        /* Asegurar que el contenido no se superponga */
        main {
            width: 100%;
            max-width: 100%;
            overflow-x: hidden;
        }
    </style>
</head>
<body>
    <div class="auth-wrapper">
        <!-- Logo fijo responsive -->
        <div class="auth-logo">
            <div class="container-fluid">
                <a asp-controller="Home" asp-action="Index">
                    <i class="bi bi-lightning-charge-fill"></i>GAMESTORE
                </a>
            </div>
        </div>

        <!-- Contenido principal -->
        <main role="main" class="page-transition">
            @RenderBody()
        </main>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>