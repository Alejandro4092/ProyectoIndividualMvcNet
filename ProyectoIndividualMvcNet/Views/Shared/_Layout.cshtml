@using ProyectoIndividualMvcNet.Extensions
<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GameStore</title>

    <!-- Bootstrap 5.3 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProyectoIndividualMvcNet.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <style>
        :root {
            --gaming-primary: #00ff88;
            --gaming-secondary: #0a84ff;
            --gaming-accent: #ff006e;
            --gaming-dark: #0d1117;
            --gaming-darker: #010409;
            --gaming-gray: #161b22;
        }

        body {
            font-family: 'Rajdhani', sans-serif;
            background: linear-gradient(135deg, var(--gaming-darker) 0%, var(--gaming-dark) 50%, #1a1f2e 100%);
            background-attachment: fixed;
            color: #e6edf3;
            min-height: 100vh;
        }

        h1, h2, h3, h4, h5, h6, .display-1, .display-2, .display-3, .display-4 {
            font-family: 'Orbitron', sans-serif;
        }

        /* Navbar Gaming */
        .navbar-gaming {
            background: rgba(13, 17, 23, 0.95) !important;
            backdrop-filter: blur(10px);
            border-bottom: 2px solid var(--gaming-primary);
            box-shadow: 0 4px 20px rgba(0, 255, 136, 0.1);
        }

        .navbar-brand {
            font-family: 'Orbitron', sans-serif;
            font-weight: 900;
            font-size: 1.8rem;
            background: linear-gradient(45deg, var(--gaming-primary), var(--gaming-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 0 30px rgba(0, 255, 136, 0.5);
        }

        .navbar-brand:hover {
            filter: brightness(1.2);
        }

        .nav-link {
            color: #e6edf3 !important;
            font-weight: 600;
            font-size: 1.1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            position: relative;
            transition: all 0.3s ease;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 50%;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--gaming-primary), var(--gaming-secondary));
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }

        .nav-link:hover::after,
        .nav-link.active::after {
            width: 80%;
        }

        .nav-link:hover {
            color: var(--gaming-primary) !important;
            transform: translateY(-2px);
        }

        /* Botones Gaming */
        .btn-gaming {
            background: linear-gradient(45deg, var(--gaming-primary), var(--gaming-secondary));
            border: none;
            color: #000;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 10px 25px;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .btn-gaming::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.3);
            transition: left 0.5s ease;
        }

        .btn-gaming:hover::before {
            left: 100%;
        }

        .btn-gaming:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(0, 255, 136, 0.4);
        }

        /* Search Bar */
        .search-gaming {
            background: var(--gaming-gray);
            border: 2px solid transparent;
            color: #e6edf3;
            border-radius: 50px;
            transition: all 0.3s ease;
        }

        .search-gaming:focus {
            background: var(--gaming-dark);
            border-color: var(--gaming-primary);
            box-shadow: 0 0 20px rgba(0, 255, 136, 0.3);
            color: #e6edf3;
        }

        /* User Menu */
        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid var(--gaming-primary);
            background: linear-gradient(45deg, var(--gaming-primary), var(--gaming-secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .user-avatar:hover {
            transform: scale(1.1);
            box-shadow: 0 0 20px rgba(0, 255, 136, 0.6);
        }

        /* Footer Gaming */
        .footer-gaming {
            background: var(--gaming-darker);
            border-top: 2px solid var(--gaming-primary);
            padding: 40px 0 20px;
            margin-top: 60px;
        }

        .footer-gaming h5 {
            color: var(--gaming-primary);
            font-weight: 700;
            margin-bottom: 20px;
        }

        .footer-gaming a {
            color: #8b949e;
            text-decoration: none;
            transition: all 0.3s ease;
            display: block;
            padding: 5px 0;
        }

        .footer-gaming a:hover {
            color: var(--gaming-primary);
            padding-left: 10px;
        }

        .social-links a {
            width: 45px;
            height: 45px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--gaming-gray);
            border-radius: 50%;
            margin: 0 5px;
            color: #e6edf3;
            font-size: 1.2rem;
            transition: all 0.3s ease;
        }

        .social-links a:hover {
            background: var(--gaming-primary);
            color: #000;
            transform: translateY(-5px);
            box-shadow: 0 5px 20px rgba(0, 255, 136, 0.5);
        }

        /* Badge Gaming */
        .badge-gaming {
            background: var(--gaming-accent);
            color: white;
            font-weight: 700;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            position: absolute;
            top: -8px;
            right: -8px;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.1);
            }
        }

        /* Container principal */
        main {
            min-height: calc(100vh - 200px);
        }

        /* Scrollbar personalizado */
        ::-webkit-scrollbar {
            width: 12px;
        }

        ::-webkit-scrollbar-track {
            background: var(--gaming-darker);
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, var(--gaming-primary), var(--gaming-secondary));
            border-radius: 6px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--gaming-primary);
        }

        /* Animación de carga */
        .page-transition {
            animation: fadeIn 0.5s ease-in;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>
    @{
        // Obtener el carrito de la sesión para mostrar la cantidad
        var carritoLayout = Context.Session.GetObject<List<ProyectoIndividualMvcNet.Models.Juego>>("CARRITO") 
                            ?? new List<ProyectoIndividualMvcNet.Models.Juego>();
        int cantidadCarritoLayout = carritoLayout.Count;
    }

    <!-- Navbar -->
    <header>
        <nav class="navbar navbar-gaming navbar-expand-lg sticky-top">
            <div class="container-fluid px-4">
                <!-- Logo -->
                <a class="navbar-brand" asp-controller="Juegos" asp-action="Index">
                    <i class="bi bi-lightning-charge-fill me-2"></i>GAMESTORE
                </a>

                <!-- Toggle para móvil -->
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <!-- Menú principal -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i>Inicio
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Juegos" asp-action="Index">
                                <i class="bi bi-controller me-1"></i>Juegos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Juegos" asp-action="MisCompras">
                                <i class="bi bi-collection-play me-1"></i>Mis Compras
                            </a>
                        </li>
                    </ul>

                    <!-- Barra de búsqueda -->
                    <form class="d-flex me-3 mb-2 mb-lg-0" role="search" asp-controller="Juegos" asp-action="Index" method="get">
                        <div class="input-group">
                            <input class="form-control search-gaming" type="search" name="texto" placeholder="Buscar juegos..." aria-label="Search">
                            <button class="btn btn-gaming" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>

                    <!-- Menú usuario -->
                    <ul class="navbar-nav">
                        <li class="nav-item position-relative me-3">
                            <a class="nav-link" asp-controller="Carrito" asp-action="Index">
                                <i class="bi bi-cart3" style="font-size: 1.5rem;"></i>
                                @if (cantidadCarritoLayout > 0)
                                {
                                    <span class="badge-gaming">@cantidadCarritoLayout</span>
                                }
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                                <div class="user-avatar me-2">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                                <span class="d-none d-lg-inline">Usuario</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark">
                                <li>
                                    <a class="dropdown-item" asp-controller="Usuarios" asp-action="Perfil">
                                        <i class="bi bi-person-circle me-2"></i>Mi Perfil
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Juegos" asp-action="MisCompras">
                                        <i class="bi bi-bag-check me-2"></i>Mis Compras
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Usuarios" asp-action="AdminUsuarios">
                                        <i class="bi bi-people-fill me-2"></i>Panel de Admin
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Juegos" asp-action="PanelEstadisticas">
                                        <i class="bi bi-graph-up-arrow me-2"></i>Estadísticas
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Usuarios" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Contenido principal -->
    <main role="main" class="page-transition">
        @RenderBody()
    </main>

    <!-- Footer Gaming -->
    <footer class="footer-gaming">
        <div class="container">
            <div class="row g-4">
                <!-- Columna 1: Sobre nosotros -->
                <div class="col-lg-4 col-md-6">
                    <h5 class="mb-3">
                        <i class="bi bi-lightning-charge-fill me-2"></i>GAMESTORE
                    </h5>
                    <p class="text-muted">
                        Tu tienda online de videojuegos favorita.
                        Los mejores títulos para todas las plataformas al mejor precio.
                    </p>
                    <div class="social-links mt-4">
                        <a href="#"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-twitter-x"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-youtube"></i></a>
                        <a href="#"><i class="bi bi-discord"></i></a>
                    </div>
                </div>

                <!-- Columna 2: Enlaces rápidos -->
                <div class="col-lg-2 col-md-6">
                    <h5>Enlaces</h5>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="Index"><i class="bi bi-chevron-right me-1"></i>Inicio</a></li>
                        <li><a asp-controller="Juegos" asp-action="Index"><i class="bi bi-chevron-right me-1"></i>Juegos</a></li>
                        <li><a asp-controller="Juegos" asp-action="MisCompras"><i class="bi bi-chevron-right me-1"></i>Mis Compras</a></li>
                        <li><a asp-controller="Carrito" asp-action="Index"><i class="bi bi-chevron-right me-1"></i>Carrito</a></li>
                        <li><a href="#contacto"><i class="bi bi-chevron-right me-1"></i>Contacto</a></li>
                    </ul>
                </div>

                <!-- Columna 3: Soporte -->
                <div class="col-lg-3 col-md-6">
                    <h5>Soporte</h5>
                    <ul class="list-unstyled">
                        <li><a href="#ayuda"><i class="bi bi-question-circle me-1"></i>Ayuda</a></li>
                        <li><a href="#privacidad"><i class="bi bi-shield-check me-1"></i>Política de Privacidad</a></li>
                        <li><a href="#terminos"><i class="bi bi-file-text me-1"></i>Términos y Condiciones</a></li>
                        <li><a href="#devoluciones"><i class="bi bi-arrow-return-left me-1"></i>Devoluciones</a></li>
                        <li><a href="#pagos"><i class="bi bi-credit-card me-1"></i>Métodos de Pago</a></li>
                    </ul>
                </div>

                <!-- Columna 4: Contacto -->
                <div class="col-lg-3 col-md-6">
                    <h5>Contacto</h5>
                    <ul class="list-unstyled text-muted">
                        <li class="mb-2">
                            <i class="bi bi-envelope me-2"></i>
                            info@gamestore.com
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-telephone me-2"></i>
                            +34 900 123 456
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-geo-alt me-2"></i>
                            Madrid, España
                        </li>
                    </ul>
                </div>
            </div>

            <hr class="my-4 border-secondary">

            <div class="row">
                <div class="col-md-6 text-center text-md-start">
                    <p class="text-muted mb-0">
                        &copy; 2026 GameStore. Todos los derechos reservados.
                    </p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <p class="text-muted mb-0">
                        Hecho con <i class="bi bi-heart-fill text-danger"></i> para gamers
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Marcar link activo
        document.addEventListener('DOMContentLoaded', function() {
            const currentPath = window.location.pathname.toLowerCase();
            const navLinks = document.querySelectorAll('.nav-link');

            navLinks.forEach(link => {
                const linkPath = link.getAttribute('href');
                if (linkPath && currentPath.includes(linkPath.toLowerCase())) {
                    link.classList.add('active');
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>