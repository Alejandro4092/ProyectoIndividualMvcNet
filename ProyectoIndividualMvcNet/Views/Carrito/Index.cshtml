@model List<ProyectoIndividualMvcNet.Models.Juego>

@{
    ViewData["Title"] = "Mi Carrito";
}

<!-- Hero Section -->
<div class="bg-dark text-white py-5 mb-4">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-12 text-center">
                <h1 class="display-4 fw-bold mb-3">
                    <i class="bi bi-cart3 me-3" style="color: var(--gaming-accent, #ff006e);"></i>
                    Mi Carrito de Compras
                </h1>
                <p class="lead mb-0">Revisa tus juegos antes de finalizar la compra</p>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    @if (Model != null && Model.Count > 0)
    {
        <div class="row">
            <!-- Lista de juegos en el carrito -->
            <div class="col-lg-8">
                <div class="card bg-dark border-0 shadow-lg mb-4">
                    <div class="card-header border-0 py-3" style="background: linear-gradient(90deg, var(--gaming-accent, #ff006e) 0%, transparent 100%);">
                        <h4 class="mb-0 text-white">
                            <i class="bi bi-bag-check me-2"></i>Juegos en tu carrito (@Model.Count)
                        </h4>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-dark table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th style="width: 100px;">Imagen</th>
                                        <th>Juego</th>
                                        <th>Género</th>
                                        <th>Plataforma</th>
                                        <th class="text-end">Precio</th>
                                        <th style="width: 100px;" class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.Img))
                                                {
                                                    <img src="@item.Img" class="rounded" style="width: 80px; height: 60px; object-fit: cover;" alt="@item.Titulo" />
                                                }
                                                else
                                                {
                                                    <div class="bg-secondary rounded d-flex align-items-center justify-content-center" style="width: 80px; height: 60px;">
                                                        <i class="bi bi-controller text-white"></i>
                                                    </div>
                                                }
                                            </td>
                                            <td class="align-middle">
                                                <strong class="text-white">@item.Titulo</strong>
                                            </td>
                                            <td class="align-middle">
                                                <span class="badge bg-primary">
                                                    <i class="bi bi-tag-fill me-1"></i>@item.Genero
                                                </span>
                                            </td>
                                            <td class="align-middle">
                                                <span class="badge bg-info">
                                                    <i class="bi bi-joystick me-1"></i>@item.Plataforma
                                                </span>
                                            </td>
                                            <td class="align-middle text-end">
                                                <h5 class="mb-0 fw-bold" style="color: var(--gaming-primary, #00ff88);">
                                                    @item.Precio.ToString("C")
                                                </h5>
                                            </td>
                                            <td class="align-middle text-center">
                                                <a asp-controller="Carrito" asp-action="Quitar" asp-route-idjuego="@item.Id"
                                                   class="btn btn-outline-danger btn-sm"
                                                   title="Eliminar del carrito">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Resumen del pedido -->
            <div class="col-lg-4">
                <div class="card bg-dark border-0 shadow-lg sticky-top" style="top: 100px;">
                    <div class="card-header border-0 py-3" style="background: linear-gradient(90deg, var(--gaming-primary, #00ff88) 0%, transparent 100%);">
                        <h4 class="mb-0 text-dark fw-bold">
                            <i class="bi bi-calculator me-2"></i>Resumen del Pedido
                        </h4>
                    </div>
                    <div class="card-body p-4">
                        <!-- Detalles del pedido -->
                        <div class="mb-3 pb-3 border-bottom border-secondary">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Juegos:</span>
                                <strong class="text-white">@Model.Count</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Subtotal:</span>
                                <strong class="text-white">@Model.Sum(x => x.Precio).ToString("C")</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Impuestos (IVA):</span>
                                <strong class="text-white">@((Model.Sum(x => x.Precio) * 0.21m).ToString("C"))</strong>
                            </div>
                        </div>

                        <!-- Total -->
                        <div class="mb-4 pb-3 border-bottom border-secondary">
                            <div class="d-flex justify-content-between align-items-center">
                                <h4 class="mb-0 text-white">Total:</h4>
                                <h3 class="mb-0 fw-bold" style="color: var(--gaming-primary, #00ff88);">
                                    @((Model.Sum(x => x.Precio) * 1.21m).ToString("C"))
                                </h3>
                            </div>
                        </div>

                        <!-- Botones de acción -->
                        <div class="d-grid gap-2">
                            <a asp-controller="Carrito" asp-action="FinalizarCompra"
                               class="btn btn-lg fw-bold shadow-lg"
                               style="background: var(--gaming-primary, #00ff88); color: #000;">
                                <i class="bi bi-credit-card me-2"></i>Confirmar y Pagar
                            </a>
                            <a asp-controller="Juegos" asp-action="Index"
                               class="btn btn-outline-light btn-lg">
                                <i class="bi bi-arrow-left me-2"></i>Seguir Comprando
                            </a>
                        </div>

                        <!-- Información adicional -->
                        <div class="mt-4 pt-3 border-top border-secondary">
                            <small class="text-muted d-block mb-2">
                                <i class="bi bi-shield-check me-1" style="color: var(--gaming-primary, #00ff88);"></i>
                                Compra 100% segura
                            </small>
                            <small class="text-muted d-block mb-2">
                                <i class="bi bi-truck me-1" style="color: var(--gaming-primary, #00ff88);"></i>
                                Descarga inmediata
                            </small>
                            <small class="text-muted d-block">
                                <i class="bi bi-arrow-clockwise me-1" style="color: var(--gaming-primary, #00ff88);"></i>
                                Garantía de 30 días
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Carrito vacío -->
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card bg-dark border-0 shadow-lg text-center p-5">
                    <div class="card-body">
                        <i class="bi bi-cart-x" style="font-size: 6rem; color: var(--gaming-accent, #ff006e); opacity: 0.5;"></i>
                        <h2 class="text-white mt-4 mb-3">Tu carrito está vacío</h2>
                        <p class="text-muted mb-4">
                            ¡No hay juegos en tu carrito! Explora nuestro catálogo y encuentra tu próxima aventura.
                        </p>
                        <a asp-controller="Juegos" asp-action="Index"
                           class="btn btn-lg shadow-lg"
                           style="background: var(--gaming-primary, #00ff88); color: #000; font-weight: bold;">
                            <i class="bi bi-shop me-2"></i>Explorar Juegos
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Mensaje de confirmación -->
@if (TempData["MENSAJE"] != null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
        <div class="toast show" role="alert">
            <div class="toast-header" style="background: var(--gaming-primary, #00ff88); color: #000;">
                <i class="bi bi-check-circle-fill me-2"></i>
                <strong class="me-auto">¡Éxito!</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body bg-dark text-white">
                @TempData["MENSAJE"]
            </div>
        </div>
    </div>
}

<style>
    /* Variables CSS */
    :root {
        --gaming-primary: #00ff88;
        --gaming-secondary: #0a84ff;
        --gaming-accent: #ff006e;
    }

    /* Tabla responsive mejorada */
    .table-dark {
        color: #e6edf3;
    }

        .table-dark thead th {
            border-bottom: 2px solid var(--gaming-accent, #ff006e);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
        }

        .table-dark tbody tr {
            transition: all 0.3s ease;
        }

            .table-dark tbody tr:hover {
                background-color: rgba(0, 255, 136, 0.1) !important;
                transform: scale(1.01);
            }

    /* Sticky sidebar */
    .sticky-top {
        position: sticky;
        top: 100px;
        z-index: 10;
    }

    /* Animación del botón de pagar */
    .btn[style*="--gaming-primary"]:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 30px rgba(0, 255, 136, 0.5) !important;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .sticky-top {
            position: relative;
            top: 0;
        }

        .display-4 {
            font-size: 2rem !important;
        }

        .table {
            font-size: 0.85rem;
        }
    }
</style>